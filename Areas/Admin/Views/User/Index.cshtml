@model List<ShopManagementSystem.Models.ApplicationUser>
@{ ViewData["Title"] = "ইউজার ম্যানেজমেন্ট"; }

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>নাম</th>
                    <th>ইমেইল</th>
                    <th>ফোন</th>
                    <th class="text-center">রোল</th>
                    <th>নিবন্ধনের তারিখ</th>
                    <th class="text-center">অ্যাকশন</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var role = ((Dictionary<string, string>)ViewBag.UserRoles).GetValueOrDefault(user.Id, "User");
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center fw-bold"
                                     style="width:36px;height:36px;font-size:.85rem">
                                    @user.FullName[0]
                                </div>
                                <div>
                                    <div class="fw-medium small">@user.FullName</div>
                                </div>
                            </div>
                        </td>
                        <td class="small">@user.Email</td>
                        <td class="small">@user.PhoneNumber</td>
                        <td class="text-center">
                            <span class="badge @(role == "Admin" ? "bg-danger" : "bg-primary") rounded-pill">@role</span>
                        </td>
                        <td class="text-muted small">@user.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="Detail" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form asp-action="ToggleRole" asp-route-id="@user.Id" method="post"
                                      onsubmit="return confirm('এই ইউজারের রোল পরিবর্তন করবেন?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="রোল পরিবর্তন">
                                        <i class="bi bi-shield-lock"></i>
                                    </button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post"
                                      onsubmit="return confirm('ইউজারটি মুছবেন? সব ডেটা হারিয়ে যাবে।')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-5">কোনো ইউজার নেই</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-white text-muted small">মোট @Model.Count জন ইউজার</div>
</div>
