@model List<ShopManagementSystem.Models.Order>
@{ ViewData["Title"] = "অর্ডার ম্যানেজমেন্ট"; }

<!-- Status filter tabs -->
<div class="d-flex gap-2 mb-4 flex-wrap">
    <a asp-action="Index" class="btn btn-sm @(ViewBag.Status == null ? "btn-dark" : "btn-outline-dark")">
        সব
    </a>
    @foreach (var status in (string[])ViewBag.StatusList)
    {
        <a asp-action="Index" asp-route-status="@status"
           class="btn btn-sm @(ViewBag.Status == status ? "btn-dark" : "btn-outline-secondary")">
            @status
            @if (status == "Pending" && (int)ViewBag.PendingCount > 0)
            {
                <span class="badge bg-danger ms-1">@ViewBag.PendingCount</span>
            }
        </a>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>ইউজার</th>
                    <th>ফোন</th>
                    <th>তারিখ</th>
                    <th>আইটেম</th>
                    <th>মোট</th>
                    <th>স্ট্যাটাস</th>
                    <th class="text-center">অ্যাকশন</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="fw-bold">#@order.Id</td>
                        <td>
                            <div class="small fw-medium">@order.User?.FullName</div>
                            <div class="text-muted" style="font-size:.75rem">@order.User?.Email</div>
                        </td>
                        <td class="small">@order.Phone</td>
                        <td class="small text-muted">@order.OrderDate.ToString("dd MMM yyyy")</td>
                        <td class="text-center">
                            <span class="badge bg-secondary rounded-pill">@order.OrderDetails.Count</span>
                        </td>
                        <td class="fw-semibold small">৳@order.TotalAmount.ToString("N0")</td>
                        <td>
                            <span class="badge badge-status-@order.Status rounded-pill px-2 py-1">
                                @order.Status
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="Detail" asp-route-id="@order.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@order.Id" method="post"
                                      onsubmit="return confirm('অর্ডার #@order.Id মুছবেন?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-5">কোনো অর্ডার নেই</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-white text-muted small">মোট @Model.Count টি অর্ডার</div>
</div>
