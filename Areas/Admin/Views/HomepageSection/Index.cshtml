@model List<ShopManagementSystem.Models.HomepageSection>
@{
    ViewData["Title"] = "হোমপেজ সেকশন ম্যানেজমেন্ট";
}

<div class="d-flex justify-content-end mb-4">
    <a asp-action="Create" class="btn btn-dark">
        <i class="bi bi-plus-circle me-2"></i>নতুন সেকশন
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-layout-text-window display-3 d-block mb-3 opacity-25"></i>
        <h5>কোনো সেকশন নেই</h5>
        <a asp-action="Create" class="btn btn-dark mt-2">প্রথম সেকশন তৈরি করুন</a>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ক্রম</th>
                        <th>শিরোনাম</th>
                        <th>ধরন</th>
                        <th>আইটেম</th>
                        <th>রং</th>
                        <th class="text-center">স্ট্যাটাস</th>
                        <th class="text-center">অ্যাকশন</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sec in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    <form asp-action="MoveUp" asp-route-id="@sec.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-xs btn-light p-1 lh-1" title="উপরে">
                                            <i class="bi bi-chevron-up" style="font-size:.7rem"></i>
                                        </button>
                                    </form>
                                    <span class="fw-bold text-center small">@sec.SortOrder</span>
                                    <form asp-action="MoveDown" asp-route-id="@sec.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-xs btn-light p-1 lh-1" title="নিচে">
                                            <i class="bi bi-chevron-down" style="font-size:.7rem"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                            <td>
                                <div class="fw-semibold small">@sec.Title</div>
                                @if (!string.IsNullOrEmpty(sec.SubTitle))
                                {
                                    <div class="text-muted" style="font-size:.75rem">@sec.SubTitle</div>
                                }
                                @if (!string.IsNullOrEmpty(sec.ButtonText))
                                {
                                    <span class="badge bg-light text-dark border" style="font-size:.7rem">
                                        বাটন: @sec.ButtonText
                                    </span>
                                }
                            </td>
                            <td>
                                @{
                                    var typeLabel = sec.SectionType switch
                                    {
                                        "category" => ("bi-tag", "ক্যাটাগরি", "bg-primary"),
                                        "combo" => ("bi-gift", "কম্বো", "bg-danger"),
                                        "product" => ("bi-box-seam", "পণ্য", "bg-success"),
                                        "banner" => ("bi-image", "ব্যানার", "bg-warning text-dark"),
                                        _ => ("bi-grid", sec.SectionType, "bg-secondary")
                                    };
                                }
                                <span class="badge @typeLabel.Item3 rounded-pill px-2">
                                    <i class="bi @typeLabel.Item1 me-1"></i>@typeLabel.Item2
                                </span>
                            </td>
                            <td class="small">
                                @if (sec.SectionType == "category")
                                {
                                    <span>@sec.Categories.Count টি ক্যাটাগরি</span>
                                }
                                else if (sec.SectionType == "product")
                                {
                                    <span>@sec.Products.Count টি পণ্য</span>
                                }
                                else if (sec.SectionType == "combo")
                                {
                                    <span>কম্বো অফার</span>
                                }
                                else
                                {
                                    <span>ব্যানার</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1 align-items-center">
                                    <div class="rounded border" style="width:20px;height:20px;background:@sec.BgColor"></div>
                                    <div class="rounded border" style="width:20px;height:20px;background:@sec.TextColor"></div>
                                </div>
                            </td>
                            <td class="text-center">
                                <form asp-action="ToggleActive" asp-route-id="@sec.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm @(sec.IsActive ? "btn-success" : "btn-secondary")"
                                            style="min-width:70px">
                                        @(sec.IsActive ? "সক্রিয়" : "নিষ্ক্রিয়")
                                    </button>
                                </form>
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-action="Edit" asp-route-id="@sec.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@sec.Id" method="post"
                                          onsubmit="return confirm('সেকশনটি মুছবেন?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white text-muted small">
            মোট @Model.Count টি সেকশন — উপরে নিচে সরিয়ে হোমপেজে সাজান
        </div>
    </div>
}