@model ProductCreateViewModel
@{
    ViewData["Title"] = "নতুন প্রোডাক্ট যোগ করুন";
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="row g-4">
                <!-- ── Left: Main Info ───────────────────────────────────── -->
                <div class="col-lg-8">

                    <!-- Basic Info -->
                    <div class="card border-0 bg-light mb-3">
                        <div class="card-body">
                            <h6 class="fw-bold mb-3">📦 মূল তথ্য</h6>
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label class="form-label fw-medium small">প্রোডাক্টের নাম <span class="text-danger">*</span></label>
                                    <input asp-for="Name" class="form-control" placeholder="প্রোডাক্টের নাম" />
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-medium small">প্রোডাক্ট কোড</label>
                                    <input asp-for="ProductCode" class="form-control" placeholder="SKU-001" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-medium small">ক্যাটাগরি <span class="text-danger">*</span></label>
                                    <select asp-for="CategoryId" asp-items="(SelectList)ViewBag.Categories" class="form-select">
                                        <option value="">-- নির্বাচন করুন --</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-medium small">স্টক <span class="text-danger">*</span></label>
                                    <input asp-for="Stock" type="number" min="0" class="form-control" placeholder="0" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Pricing -->
                    <div class="card border-0 bg-light mb-3">
                        <div class="card-body">
                            <h6 class="fw-bold mb-3">💰 মূল্য তথ্য</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label fw-medium small">ক্রয় মূল্য (৳)</label>
                                    <input asp-for="PurchasePrice" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-medium small">বিক্রয় মূল্য (৳) <span class="text-danger">*</span></label>
                                    <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-medium small">VAT (%)</label>
                                    <input asp-for="ProductVat" type="number" step="0.01" class="form-control" placeholder="0" />
                                </div>

                                <!-- Discount -->
                                <div class="col-md-4">
                                    <label class="form-label fw-medium small">ছাড়ের মূল্য (৳)</label>
                                    <input asp-for="DiscountPrice" type="number" step="0.01" class="form-control" placeholder="ঐচ্ছিক" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-medium small">ছাড় শুরু</label>
                                    <input asp-for="DiscountStartDate" type="date" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-medium small">ছাড় শেষ</label>
                                    <input asp-for="DiscountEndDate" type="date" class="form-control" />
                                </div>
                                <div class="col-12">
                                    <div class="form-check form-switch">
                                        <input asp-for="IsDiscountFixed" class="form-check-input" type="checkbox" checked />
                                        <label class="form-check-label small">Fixed Amount ছাড় (unchecked = % ছাড়)</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label class="form-label fw-medium small">বিবরণ</label>
                        <textarea asp-for="Description" class="form-control" rows="4"
                                  placeholder="প্রোডাক্টের বিস্তারিত বিবরণ..."></textarea>
                    </div>

                    <!-- ── Size Management ───────────────────────────────── -->
                    <div class="card border-0 bg-light">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-bold mb-0">📏 সাইজ ও মূল্য (ঐচ্ছিক)</h6>
                                <button type="button" class="btn btn-sm btn-dark" onclick="addSizeRow()">
                                    <i class="bi bi-plus-circle me-1"></i>সাইজ যোগ করুন
                                </button>
                            </div>
                            <div class="small text-muted mb-3">
                                সাইজ যোগ করলে প্রতিটি সাইজের আলাদা মূল্য ও স্টক নির্ধারণ করা যাবে।
                            </div>
                            <div id="sizeContainer">
                                <!-- Rows added dynamically -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Right: Images + Status ────────────────────────────── -->
                <div class="col-lg-4">
                    <div class="card border-0 bg-light mb-3" style="border: 2px dashed #dee2e6 !important">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3"><i class="bi bi-images me-2"></i>প্রোডাক্ট ছবি</h6>
                            <input type="file" name="Images" id="imgUpload" class="form-control form-control-sm"
                                   multiple accept="image/*" onchange="previewImages(this)" />
                            <div class="form-text mb-2">একাধিক ছবি — প্রথমটি প্রধান ছবি।</div>
                            <div id="imgPreview" class="d-flex flex-wrap gap-2"></div>
                        </div>
                    </div>
                    <div class="card border-0 bg-light">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">⚙️ স্ট্যাটাস</h6>
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                                <label class="form-check-label fw-medium">সক্রিয় (ইউজারদের দেখাবে)</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="my-4" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4">
                    <i class="bi bi-check-circle me-2"></i>প্রোডাক্ট সেভ করুন
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">বাতিল</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        var sizeIndex = 0;

        function addSizeRow() {
            var i = sizeIndex++;
            var html = `
            <div class="row g-2 align-items-end mb-2 size-row" id="sizeRow${i}">
                <div class="col-md-3">
                    <label class="form-label fw-medium" style="font-size:.78rem">সাইজের নাম <span class="text-danger">*</span></label>
                    <input type="text" name="Sizes[${i}].SizeName" class="form-control form-control-sm"
                           placeholder="S, M, XL, 42..." required />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-medium" style="font-size:.78rem">কোড</label>
                    <input type="text" name="Sizes[${i}].SizeCode" class="form-control form-control-sm" placeholder="ঐচ্ছিক" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-medium" style="font-size:.78rem">বিক্রয় মূল্য (৳) <span class="text-danger">*</span></label>
                    <input type="number" step="0.01" name="Sizes[${i}].SalesPrice" class="form-control form-control-sm"
                           placeholder="0.00" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-medium" style="font-size:.78rem">স্টক</label>
                    <input type="number" name="Sizes[${i}].Stock" class="form-control form-control-sm"
                           placeholder="0" value="0" min="0" />
                </div>
                <div class="col-md-2 d-flex gap-1 align-items-end">
                    <div class="form-check form-switch">
                        <input type="checkbox" name="Sizes[${i}].IsActive" class="form-check-input"
                               id="sizeActive${i}" value="true" checked />
                        <input type="hidden" name="Sizes[${i}].IsActive" value="false" />
                        <label class="form-check-label small" for="sizeActive${i}">সক্রিয়</label>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-danger"
                            onclick="document.getElementById('sizeRow${i}').remove()">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            </div>`;
            document.getElementById('sizeContainer').insertAdjacentHTML('beforeend', html);
        }

        function previewImages(input) {
            var preview = document.getElementById('imgPreview');
            preview.innerHTML = '';
            Array.from(input.files).forEach(function(file) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    var img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'rounded border';
                    img.style.cssText = 'width:72px;height:72px;object-fit:cover';
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        }
    </script>
}
