@model List<ShopManagementSystem.Models.ChatSession>
@{
    ViewData["Title"] = "চ্যাট সাপোর্ট";
}

<div class="row g-4">

    <!-- ── Session List ─────────────────────────────────────────────────── -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-chat-dots me-2 text-primary"></i>কথোপকথন
                </h6>
                @if ((int)ViewBag.TotalUnread > 0)
                {
                    <span class="badge bg-danger rounded-pill">@ViewBag.TotalUnread</span>
                }
            </div>
            <div class="list-group list-group-flush overflow-auto" style="max-height:70vh"
                 id="sessionList">
                @if (!Model.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-chat-square display-3 d-block mb-2 opacity-25"></i>
                        <p class="small">কোনো চ্যাট নেই</p>
                    </div>
                }
                @foreach (var session in Model)
                {
                    <a asp-area="Admin" asp-controller="Chat" asp-action="Conversation"
                       asp-route-userId="@session.UserId"
                       class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3 px-3
                                  @(session.UnreadCount > 0 ? "bg-light" : "")">
                        <!-- Avatar -->
                        <div class="rounded-circle bg-dark text-white d-flex align-items-center
                                        justify-content-center flex-shrink-0 fw-bold"
                             style="width:42px;height:42px">
                            @(session.User?.FullName?.FirstOrDefault().ToString().ToUpper() ?? "U")
                        </div>
                        <div class="flex-grow-1 overflow-hidden">
                            <div class="fw-semibold small">@session.User?.FullName</div>
                            <div class="text-muted" style="font-size:.75rem">@session.User?.Email</div>
                            <div class="text-muted" style="font-size:.7rem">
                                @session.LastMessageAt.ToString("dd MMM, hh:mm tt")
                            </div>
                        </div>
                        @if (session.UnreadCount > 0)
                        {
                            <span class="badge bg-danger rounded-pill flex-shrink-0">
                                @session.UnreadCount
                            </span>
                        }
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- ── Right panel placeholder ──────────────────────────────────────── -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100 d-flex align-items-center justify-content-center"
             style="min-height:400px">
            <div class="text-center text-muted">
                <i class="bi bi-chat-left-dots display-2 d-block mb-3 opacity-25"></i>
                <h5>একটি কথোপকথন নির্বাচন করুন</h5>
                <p class="small">বাম দিক থেকে ইউজার নির্বাচন করুন।</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        // নতুন user message এলে session list update করো
        connection.on("ReceiveMessage", function(data) {
            if (!data.isFromAdmin) {
                // Unread badge update
                playNotificationSound();
                // Page refresh করলে দেখা যাবে — অথবা dynamic update
                var badge = document.querySelector(`[data-user="${data.senderId}"] .badge`);
                if (badge) {
                    badge.textContent = parseInt(badge.textContent || 0) + 1;
                }
            }
        });

        connection.on("UserOnline", function(user) {
            console.log("User online:", user.userName);
        });

        connection.start().catch(console.error);

        function playNotificationSound() {
            try {
                var ctx = new (window.AudioContext || window.webkitAudioContext)();
                var osc = ctx.createOscillator();
                var g   = ctx.createGain();
                osc.connect(g); g.connect(ctx.destination);
                osc.frequency.value = 700;
                g.gain.setValueAtTime(0.15, ctx.currentTime);
                g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.4);
                osc.start(); osc.stop(ctx.currentTime + 0.4);
            } catch(e) {}
        }

        // Auto refresh every 30s for new sessions
        setInterval(function() { location.reload(); }, 30000);
    </script>
}
