@model List<ShopManagementSystem.Models.ChatMessage>
@{
    ViewData["Title"] = $"চ্যাট — {(ViewBag.TargetUser as ShopManagementSystem.Models.ApplicationUser)?.FullName}";
}

@{
    var targetUser = ViewBag.TargetUser as ShopManagementSystem.Models.ApplicationUser;
    var targetUserId = ViewBag.TargetUserId as string;
}

<div class="row g-3">
    <!-- Back button -->
    <div class="col-12">
        <a asp-area="Admin" asp-controller="Chat" asp-action="Index"
           class="btn btn-sm btn-outline-secondary mb-2">
            <i class="bi bi-arrow-left me-1"></i>সব চ্যাট
        </a>
    </div>

    <div class="col-12">
        <div class="card border-0 shadow-sm" style="height:78vh;display:flex;flex-direction:column">

            <!-- Header -->
            <div class="card-header bg-dark text-white d-flex align-items-center gap-3 py-3">
                <div class="rounded-circle bg-warning text-dark d-flex align-items-center
                            justify-content-center fw-bold flex-shrink-0"
                     style="width:42px;height:42px">
                    @(targetUser?.FullName?.FirstOrDefault().ToString().ToUpper() ?? "U")
                </div>
                <div>
                    <div class="fw-bold">@targetUser?.FullName</div>
                    <div class="small opacity-75">
                        <i class="bi bi-envelope me-1"></i>@targetUser?.Email &nbsp;
                        <i class="bi bi-telephone me-1"></i>@targetUser?.PhoneNumber
                    </div>
                </div>
                <div class="ms-auto">
                    <span class="badge bg-success rounded-pill px-2" id="onlineStatus">● অনলাইন</span>
                </div>
            </div>

            <!-- Messages -->
            <div class="card-body p-3 overflow-auto flex-grow-1" id="messageArea"
                 style="background:#f8f9fa">

                <div class="text-center mb-3">
                    <span class="badge bg-secondary rounded-pill px-3 py-2 small">
                        @targetUser?.FullName এর সাথে কথোপকথন
                    </span>
                </div>

                @if (!Model.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-chat-square-dots display-4 d-block mb-2 opacity-25"></i>
                        <p class="small">এখনো কোনো মেসেজ নেই</p>
                    </div>
                }

                @foreach (var msg in Model)
                {
                    @if (msg.IsFromAdmin)
                    {
                        <!-- Admin message — right -->
                        <div class="d-flex gap-2 mb-3 justify-content-end">
                            <div>
                                <div class="bg-dark text-white rounded-3 px-3 py-2"
                                     style="max-width:500px;border-radius:18px 4px 18px 18px !important">
                                    <div class="small">@msg.Message</div>
                                </div>
                                <div class="text-muted mt-1 text-end" style="font-size:.7rem">
                                    @msg.SentAt.ToString("dd MMM, hh:mm tt")
                                    @if (msg.IsRead)
                                    {
                                        <i class="bi bi-check2-all text-primary ms-1"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-check2 text-secondary ms-1"></i>
                                    }
                                </div>
                            </div>
                            <div class="rounded-circle bg-danger text-white d-flex align-items-center
                                                justify-content-center flex-shrink-0 fw-bold"
                                 style="width:32px;height:32px;font-size:.75rem">
                                A
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- User message — left -->
                        <div class="d-flex gap-2 mb-3">
                            <div class="rounded-circle bg-dark text-white d-flex align-items-center
                                                justify-content-center flex-shrink-0 fw-bold"
                                 style="width:32px;height:32px;font-size:.75rem">
                                @(targetUser?.FullName?.FirstOrDefault().ToString().ToUpper() ?? "U")
                            </div>
                            <div>
                                <div class="bg-white rounded-3 px-3 py-2 shadow-sm"
                                     style="max-width:500px;border-radius:4px 18px 18px 18px !important">
                                    <div class="small">@msg.Message</div>
                                </div>
                                <div class="text-muted mt-1" style="font-size:.7rem">
                                    @msg.SentAt.ToString("dd MMM, hh:mm tt")
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Typing -->
            <div id="typingIndicator" class="px-3 py-1" style="display:none;background:#f8f9fa">
                <span class="text-muted small">@targetUser?.FullName টাইপ করছেন...</span>
            </div>

            <!-- Input -->
            <div class="card-footer bg-white border-top p-3">
                <div class="d-flex gap-2">
                    <input type="text" id="messageInput" class="form-control"
                           placeholder="@targetUser?.FullName কে মেসেজ লিখুন..."
                           maxlength="1000"
                           onkeypress="if(event.key==='Enter') sendMessage()" />
                    <button class="btn btn-danger px-4 flex-shrink-0" onclick="sendMessage()">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    #messageArea::-webkit-scrollbar {
        width: 4px;
    }

    #messageArea::-webkit-scrollbar-thumb {
        background: #dee2e6;
        border-radius: 4px;
    }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const targetUserId = '@targetUserId';
        const targetName   = '@targetUser?.FullName';

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        // User এর মেসেজ পাওয়া
        connection.on("ReceiveMessage", function(data) {
            if (!data.isFromAdmin && data.senderId === targetUserId) {
                appendUserMessage(data);
                // Mark as read
                connection.invoke("MarkAsRead", targetUserId).catch(console.error);
            }
        });

        // Admin নিজের মেসেজ দেখবে
        connection.on("MessageSent", function(data) {
            if (data.targetUserId === targetUserId) {
                appendAdminMessage(data.payload || data);
            }
        });

        connection.on("UserOnline", function(user) {
            if (user.userId === targetUserId) {
                document.getElementById('onlineStatus').textContent = '● অনলাইন';
                document.getElementById('onlineStatus').className  = 'badge bg-success rounded-pill px-2';
            }
        });

        connection.on("UserOffline", function(userId) {
            if (userId === targetUserId) {
                document.getElementById('onlineStatus').textContent = '○ অফলাইন';
                document.getElementById('onlineStatus').className  = 'badge bg-secondary rounded-pill px-2';
            }
        });

        connection.start()
            .then(function() {
                scrollToBottom();
                connection.invoke("MarkAsRead", targetUserId).catch(console.error);
            })
            .catch(console.error);

        function sendMessage() {
            var input = document.getElementById('messageInput');
            var msg   = input.value.trim();
            if (!msg) return;
            input.value = '';

            connection.invoke("SendMessageToUser", targetUserId, msg).catch(function(err) {
                console.error("Send error:", err);
                alert('মেসেজ পাঠানো যায়নি।');
            });
        }

        function appendUserMessage(data) {
            var area = document.getElementById('messageArea');
            var initials = targetName ? targetName[0].toUpperCase() : 'U';
            var div  = document.createElement('div');
            div.className = 'd-flex gap-2 mb-3';
            div.innerHTML = `
                <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center flex-shrink-0 fw-bold"
                     style="width:32px;height:32px;font-size:.75rem">${initials}</div>
                <div>
                    <div class="bg-white rounded-3 px-3 py-2 shadow-sm"
                         style="max-width:500px;border-radius:4px 18px 18px 18px !important">
                        <div class="small">${escapeHtml(data.message)}</div>
                    </div>
                    <div class="text-muted mt-1" style="font-size:.7rem">${data.sentAt}</div>
                </div>`;
            area.appendChild(div);
            scrollToBottom();
        }

        function appendAdminMessage(data) {
            var area = document.getElementById('messageArea');
            var div  = document.createElement('div');
            div.className = 'd-flex gap-2 mb-3 justify-content-end';
            div.innerHTML = `
                <div>
                    <div class="bg-dark text-white rounded-3 px-3 py-2"
                         style="max-width:500px;border-radius:18px 4px 18px 18px !important">
                        <div class="small">${escapeHtml(data.message)}</div>
                    </div>
                    <div class="text-muted mt-1 text-end" style="font-size:.7rem">
                        ${data.sentAt} <i class="bi bi-check2 text-secondary ms-1"></i>
                    </div>
                </div>
                <div class="rounded-circle bg-danger text-white d-flex align-items-center justify-content-center flex-shrink-0 fw-bold"
                     style="width:32px;height:32px;font-size:.75rem">A</div>`;
            area.appendChild(div);
            scrollToBottom();
        }

        function scrollToBottom() {
            var area = document.getElementById('messageArea');
            area.scrollTop = area.scrollHeight;
        }

        function escapeHtml(text) {
            var d = document.createElement('div');
            d.appendChild(document.createTextNode(text));
            return d.innerHTML;
        }
    </script>
}
