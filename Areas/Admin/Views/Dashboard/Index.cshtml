@model AdminDashboardViewModel
@{ ViewData["Title"] = "ড্যাশবোর্ড"; }

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-3 p-3 bg-primary bg-opacity-10">
                    <i class="bi bi-box-seam text-primary fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">মোট প্রোডাক্ট</div>
                    <div class="fs-3 fw-bold">@Model.TotalProducts</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-3 p-3 bg-success bg-opacity-10">
                    <i class="bi bi-receipt text-success fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">মোট অর্ডার</div>
                    <div class="fs-3 fw-bold">@Model.TotalOrders</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                    <i class="bi bi-people text-warning fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">মোট ইউজার</div>
                    <div class="fs-3 fw-bold">@Model.TotalUsers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-3 p-3 bg-danger bg-opacity-10">
                    <i class="bi bi-currency-dollar text-danger fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">মোট আয়</div>
                    <div class="fs-3 fw-bold">৳@Model.TotalRevenue.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Recent Orders -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h6 class="fw-bold mb-0">সাম্প্রতিক অর্ডার</h6>
                <a asp-area="Admin" asp-controller="Order" asp-action="Index"
                   class="btn btn-sm btn-outline-dark">সব দেখুন</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="fw-semibold small">#</th>
                            <th class="fw-semibold small">ইউজার</th>
                            <th class="fw-semibold small">তারিখ</th>
                            <th class="fw-semibold small">পরিমাণ</th>
                            <th class="fw-semibold small">স্ট্যাটাস</th>
                            <th class="fw-semibold small"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.RecentOrders)
                        {
                            <tr>
                                <td class="small fw-medium">#@order.Id</td>
                                <td class="small">@order.User?.FullName</td>
                                <td class="small text-muted">@order.OrderDate.ToString("dd MMM, hh:mm tt")</td>
                                <td class="small fw-semibold">৳@order.TotalAmount.ToString("N0")</td>
                                <td>
                                    <span class="badge badge-status-@order.Status rounded-pill px-2 py-1">
                                        @order.Status
                                    </span>
                                </td>
                                <td>
                                    <a asp-area="Admin" asp-controller="Order" asp-action="Detail"
                                       asp-route-id="@order.Id" class="btn btn-sm btn-light">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!Model.RecentOrders.Any())
                        {
                            <tr><td colspan="6" class="text-center text-muted py-4">কোনো অর্ডার নেই</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Right column -->
    <div class="col-lg-4">
        <!-- Pending Orders Alert -->
        @if (Model.PendingOrders > 0)
        {
            <div class="alert alert-warning border-0 shadow-sm mb-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-circle-fill fs-5"></i>
                    <div>
                        <div class="fw-semibold">@Model.PendingOrders টি পেন্ডিং অর্ডার</div>
                        <div class="small">দ্রুত প্রসেস করুন</div>
                    </div>
                    <a asp-area="Admin" asp-controller="Order" asp-action="Index"
                       asp-route-status="Pending" class="btn btn-sm btn-warning ms-auto">দেখুন</a>
                </div>
            </div>
        }

        <!-- Low Stock Alert -->
        @if (Model.LowStockItems.Any())
        {
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h6 class="fw-bold mb-0 text-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>কম স্টক
                    </h6>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var p in Model.LowStockItems)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center py-2">
                            <span class="small fw-medium">@p.Name</span>
                            <span class="badge @(p.Stock == 0 ? "bg-danger" : "bg-warning text-dark") rounded-pill">
                                @(p.Stock == 0 ? "শেষ" : $"{p.Stock} বাকি")
                            </span>
                        </li>
                    }
                </ul>
                <div class="card-footer bg-white text-center">
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-sm btn-outline-dark">
                        প্রোডাক্ট ম্যানেজ করুন
                    </a>
                </div>
            </div>
        }

        <!-- Quick Links -->
        <div class="card border-0 shadow-sm mt-3">
            <div class="card-header bg-white py-3">
                <h6 class="fw-bold mb-0">দ্রুত অ্যাকশন</h6>
            </div>
            <div class="card-body d-grid gap-2">
                <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn btn-dark btn-sm">
                    <i class="bi bi-plus-circle me-2"></i>নতুন প্রোডাক্ট যোগ করুন
                </a>
                <a asp-area="Admin" asp-controller="Category" asp-action="Create" class="btn btn-outline-dark btn-sm">
                    <i class="bi bi-folder-plus me-2"></i>নতুন ক্যাটাগরি যোগ করুন
                </a>
                <a asp-area="Admin" asp-controller="Slider" asp-action="Create" class="btn btn-outline-dark btn-sm">
                    <i class="bi bi-image me-2"></i>নতুন স্লাইডার যোগ করুন
                </a>
            </div>
        </div>
    </div>
</div>
