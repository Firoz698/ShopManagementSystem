@model AdminDashboardViewModel
@{
    ViewData["Title"] = "ড্যাশবোর্ড";
}

<!-- ── আজকের Summary ──────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="alert border-0 py-2 px-3 mb-0"
             style="background:linear-gradient(135deg,#1a1a2e,#0f3460);color:#fff">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <div>
                    <i class="bi bi-calendar-check me-2 text-warning"></i>
                    <strong>আজকের সারসংক্ষেপ</strong>
                    <span class="ms-2 opacity-75 small">@DateTime.Now.ToString("dd MMMM yyyy, dddd")</span>
                </div>
                <div class="ms-auto d-flex gap-4 flex-wrap">
                    <div class="text-center">
                        <div class="fs-4 fw-bold text-warning">@Model.TodayOrderCount</div>
                        <div class="small opacity-75">আজকের অর্ডার</div>
                    </div>
                    <div class="text-center">
                        <div class="fs-4 fw-bold text-success">৳@Model.TodayRevenue.ToString("N0")</div>
                        <div class="small opacity-75">আজকের আয়</div>
                    </div>
                    <div class="text-center">
                        <div class="fs-4 fw-bold text-info">@Model.TodayNewUsers</div>
                        <div class="small opacity-75">নতুন ইউজার</div>
                    </div>
                    <div class="text-center">
                        <div class="fs-4 fw-bold text-danger">@Model.PendingOrders</div>
                        <div class="small opacity-75">পেন্ডিং অর্ডার</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Overall Stats ──────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-3 p-3 bg-primary bg-opacity-10">
                    <i class="bi bi-box-seam text-primary fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">মোট প্রোডাক্ট</div>
                    <div class="fs-3 fw-bold">@Model.TotalProducts</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-3 p-3 bg-success bg-opacity-10">
                    <i class="bi bi-receipt text-success fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">মোট অর্ডার</div>
                    <div class="fs-3 fw-bold">@Model.TotalOrders</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                    <i class="bi bi-people text-warning fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">মোট ইউজার</div>
                    <div class="fs-3 fw-bold">@Model.TotalUsers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card border-0">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-3 p-3 bg-danger bg-opacity-10">
                    <i class="bi bi-currency-dollar text-danger fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">মোট আয়</div>
                    <div class="fs-3 fw-bold">৳@Model.TotalRevenue.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Date Filter ────────────────────────────────────────────────────────── -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label fw-medium small mb-1">
                    <i class="bi bi-calendar3 me-1 text-primary"></i>তারিখ ফিল্টার
                </label>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">শুরু</label>
                <input type="date" name="startDate" class="form-control form-control-sm"
                       value="@ViewBag.StartDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1">শেষ</label>
                <input type="date" name="endDate" class="form-control form-control-sm"
                       value="@ViewBag.EndDate" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-dark btn-sm">
                    <i class="bi bi-search me-1"></i>ফিল্টার করুন
                </button>
            </div>
            <!-- Quick shortcuts -->
            <div class="col-auto d-flex gap-1 flex-wrap">
                <a href="?startDate=@DateTime.Today.ToString("yyyy-MM-dd")&endDate=@DateTime.Today.ToString("yyyy-MM-dd")"
                   class="btn btn-sm btn-outline-secondary">আজ</a>
                <a href="?startDate=@DateTime.Today.AddDays(-6).ToString("yyyy-MM-dd")&endDate=@DateTime.Today.ToString("yyyy-MM-dd")"
                   class="btn btn-sm btn-outline-secondary">৭ দিন</a>
                <a href="?startDate=@(new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1)).ToString(" yyyy-MM-dd")&endDate=@DateTime.Today.ToString("yyyy-MM-dd")"
                   class="btn btn-sm btn-outline-secondary">এই মাস</a>
                <a href="?startDate=@DateTime.Today.AddDays(-29).ToString("yyyy-MM-dd")&endDate=@DateTime.Today.ToString("yyyy-MM-dd")"
                   class="btn btn-sm btn-outline-secondary">৩০ দিন</a>
            </div>
        </form>
    </div>
</div>

<!-- ── Filtered Stats ─────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-bar-chart me-2 text-primary"></i>
                    ফিল্টার ফলাফল:
                    <span class="text-primary">@ViewBag.StartDate</span> —
                    <span class="text-primary">@ViewBag.EndDate</span>
                </h6>
                <span class="badge bg-primary rounded-pill">@Model.FilteredOrderCount টি অর্ডার</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6 col-md-3">
                        <div class="text-center p-3 bg-light rounded-3">
                            <div class="fs-2 fw-bold text-dark">@Model.FilteredOrderCount</div>
                            <div class="small text-muted">মোট অর্ডার</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="text-center p-3 rounded-3" style="background:#d1fae5">
                            <div class="fs-2 fw-bold text-success">৳@Model.FilteredRevenue.ToString("N0")</div>
                            <div class="small text-muted">মোট আয়</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="text-center p-3 rounded-3" style="background:#fef3c7">
                            <div class="fs-2 fw-bold" style="color:#92400e">@Model.FilteredPending</div>
                            <div class="small text-muted">পেন্ডিং</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="text-center p-3 rounded-3" style="background:#dbeafe">
                            <div class="fs-2 fw-bold" style="color:#1e40af">@Model.FilteredCompleted</div>
                            <div class="small text-muted">সম্পন্ন</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-2">
                        <div class="text-center p-3 rounded-3" style="background:#fee2e2">
                            <div class="fs-2 fw-bold text-danger">@Model.FilteredCancelled</div>
                            <div class="small text-muted">বাতিল</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Filtered Orders Table ──────────────────────────────────────────────── -->
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                <h6 class="fw-bold mb-0">
                    ফিল্টার করা অর্ডার (@Model.FilteredOrders.Count টি)
                </h6>
                <a asp-area="Admin" asp-controller="Order" asp-action="Index"
                   class="btn btn-sm btn-outline-dark">সব অর্ডার</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="fw-semibold small">#</th>
                            <th class="fw-semibold small">ইউজার</th>
                            <th class="fw-semibold small">তারিখ</th>
                            <th class="fw-semibold small">পরিমাণ</th>
                            <th class="fw-semibold small">স্ট্যাটাস</th>
                            <th class="fw-semibold small"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.FilteredOrders.Take(15))
                        {
                            <tr>
                                <td class="small fw-medium">#@order.Id</td>
                                <td class="small">@order.User?.FullName</td>
                                <td class="small text-muted">@order.OrderDate.ToString("dd MMM, hh:mm tt")</td>
                                <td class="small fw-semibold">৳@order.TotalAmount.ToString("N0")</td>
                                <td>
                                    <span class="badge badge-status-@order.Status rounded-pill px-2 py-1">
                                        @order.Status
                                    </span>
                                </td>
                                <td>
                                    <a asp-area="Admin" asp-controller="Order" asp-action="Detail"
                                       asp-route-id="@order.Id" class="btn btn-sm btn-light">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!Model.FilteredOrders.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox display-4 d-block mb-2 opacity-25"></i>
                                    এই সময়ের মধ্যে কোনো অর্ডার নেই
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ── Right column ───────────────────────────────────────────────────── -->
    <div class="col-lg-4">
        <!-- Pending alert -->
        @if (Model.PendingOrders > 0)
        {
            <div class="alert alert-warning border-0 shadow-sm mb-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-circle-fill fs-5"></i>
                    <div>
                        <div class="fw-semibold">@Model.PendingOrders টি পেন্ডিং অর্ডার</div>
                        <div class="small">দ্রুত প্রসেস করুন</div>
                    </div>
                    <a asp-area="Admin" asp-controller="Order" asp-action="Index"
                       asp-route-status="Pending" class="btn btn-sm btn-warning ms-auto">দেখুন</a>
                </div>
            </div>
        }

        <!-- Low stock -->
        @if (Model.LowStockItems.Any())
        {
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white py-3">
                    <h6 class="fw-bold mb-0 text-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>কম স্টক
                    </h6>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var p in Model.LowStockItems)
                    {
                        <li class="list-group-item d-flex justify-content-between py-2">
                            <span class="small fw-medium">@p.Name</span>
                            <span class="badge @(p.Stock == 0 ? "bg-danger" : "bg-warning text-dark") rounded-pill">
                                @(p.Stock == 0 ? "শেষ" : $"{p.Stock} বাকি")
                            </span>
                        </li>
                    }
                </ul>
            </div>
        }

        <!-- Quick Actions -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="fw-bold mb-0">দ্রুত অ্যাকশন</h6>
            </div>
            <div class="card-body d-grid gap-2">
                <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn btn-dark btn-sm">
                    <i class="bi bi-plus-circle me-2"></i>নতুন প্রোডাক্ট
                </a>
                <a asp-area="Admin" asp-controller="Combo" asp-action="Create" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-gift me-2"></i>নতুন কম্বো অফার
                </a>
                <a asp-area="Admin" asp-controller="Slider" asp-action="Create" class="btn btn-outline-dark btn-sm">
                    <i class="bi bi-image me-2"></i>নতুন স্লাইডার
                </a>
                <a asp-area="Admin" asp-controller="HomepageSection" asp-action="Create"
                   class="btn btn-outline-dark btn-sm">
                    <i class="bi bi-layout-text-window me-2"></i>নতুন সেকশন
                </a>
            </div>
        </div>
    </div>
</div>
