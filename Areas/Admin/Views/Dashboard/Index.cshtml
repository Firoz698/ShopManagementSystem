@model AdminDashboardViewModel
@{
    ViewData["Title"] = "ড্যাশবোর্ড";
}

<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .db-wrap {
        padding: 1.5rem 1rem;
        background: #f5f5f3;
        min-height: 100vh;
    }

    .db-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        gap: 8px;
    }

    .db-title {
        font-size: 20px;
        font-weight: 500;
        color: #1a1a18;
    }

    .db-date {
        font-size: 13px;
        color: #5f5e5a;
        background: #fff;
        border: 0.5px solid rgba(0,0,0,0.12);
        border-radius: 8px;
        padding: 6px 12px;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        margin-bottom: 1.5rem;
    }

    .stat-card {
        background: #fff;
        border-radius: 12px;
        border: 0.5px solid rgba(0,0,0,0.12);
        padding: 1.1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 14px;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .stat-card:hover {
            border-color: rgba(0,0,0,0.25);
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 18px;
    }

    .icon-blue {
        background: #E6F1FB;
        color: #185FA5;
    }

    .icon-green {
        background: #EAF3DE;
        color: #3B6D11;
    }

    .icon-amber {
        background: #FAEEDA;
        color: #854F0B;
    }

    .icon-coral {
        background: #FAECE7;
        color: #993C1D;
    }

    .stat-label {
        font-size: 12px;
        color: #888780;
        margin-bottom: 3px;
    }

    .stat-value {
        font-size: 22px;
        font-weight: 500;
        color: #1a1a18;
        line-height: 1.2;
    }

    .stat-sub {
        font-size: 11px;
        color: #3B6D11;
        margin-top: 2px;
    }

    .main-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 16px;
    }

    @@media (min-width: 760px) {
        .main-grid {
            grid-template-columns: 1fr 340px;
        }
    }

    .db-card {
        background: #fff;
        border-radius: 12px;
        border: 0.5px solid rgba(0,0,0,0.12);
        overflow: hidden;
    }

    .card-head {
        padding: 14px 18px;
        border-bottom: 0.5px solid rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .card-head-title {
        font-size: 14px;
        font-weight: 500;
        color: #1a1a18;
    }

    .btn-sm {
        font-size: 12px;
        padding: 5px 12px;
        border-radius: 8px;
        border: 0.5px solid rgba(0,0,0,0.2);
        background: transparent;
        color: #1a1a18;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

        .btn-sm:hover {
            background: #f5f5f3;
            text-decoration: none;
            color: #1a1a18;
        }

    .tbl-wrap {
        overflow-x: auto;
    }

    .db-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .db-table thead tr {
            background: #f5f5f3;
        }

        .db-table th {
            padding: 9px 14px;
            text-align: left;
            font-weight: 500;
            font-size: 12px;
            color: #888780;
            white-space: nowrap;
        }

        .db-table td {
            padding: 10px 14px;
            border-bottom: 0.5px solid rgba(0,0,0,0.08);
            color: #1a1a18;
            white-space: nowrap;
        }

        .db-table tr:last-child td {
            border-bottom: none;
        }

        .db-table tbody tr:hover td {
            background: #f5f5f3;
        }

    .badge {
        display: inline-block;
        font-size: 11px;
        padding: 3px 9px;
        border-radius: 99px;
        font-weight: 500;
    }

    .badge-status-Pending {
        background: #FAEEDA;
        color: #854F0B;
    }

    .badge-status-Processing {
        background: #E6F1FB;
        color: #185FA5;
    }

    .badge-status-Shipped {
        background: #E1F5EE;
        color: #0F6E56;
    }

    .badge-status-Delivered {
        background: #EAF3DE;
        color: #3B6D11;
    }

    .badge-status-Cancelled {
        background: #FCEBEB;
        color: #A32D2D;
    }

    .eye-btn {
        background: #f5f5f3;
        border: 0.5px solid rgba(0,0,0,0.12);
        border-radius: 8px;
        width: 28px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 13px;
        color: #888780;
        text-decoration: none;
    }

        .eye-btn:hover {
            background: #fff;
            border-color: rgba(0,0,0,0.25);
            color: #1a1a18;
        }

    .right-col {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .alert-warn {
        background: #FAEEDA;
        border: 0.5px solid #FAC775;
        border-radius: 12px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .alert-icon {
        font-size: 18px;
        flex-shrink: 0;
    }

    .alert-text {
        flex: 1;
    }

    .alert-title {
        font-size: 13px;
        font-weight: 500;
        color: #633806;
    }

    .alert-sub {
        font-size: 12px;
        color: #854F0B;
        margin-top: 1px;
    }

    .btn-warn {
        font-size: 12px;
        padding: 5px 12px;
        border-radius: 8px;
        background: #EF9F27;
        color: #fff;
        border: none;
        cursor: pointer;
        white-space: nowrap;
        text-decoration: none;
        display: inline-block;
    }

        .btn-warn:hover {
            background: #BA7517;
            color: #fff;
            text-decoration: none;
        }

    .stock-list {
        list-style: none;
    }

    .stock-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 9px 18px;
        border-bottom: 0.5px solid rgba(0,0,0,0.08);
        font-size: 13px;
    }

        .stock-item:last-child {
            border-bottom: none;
        }

    .stock-name {
        color: #1a1a18;
        font-weight: 500;
    }

    .badge-out {
        background: #FCEBEB;
        color: #A32D2D;
    }

    .badge-low {
        background: #FAEEDA;
        color: #854F0B;
    }

    .card-foot {
        padding: 10px 18px;
        border-top: 0.5px solid rgba(0,0,0,0.08);
        text-align: center;
    }

    .action-grid {
        padding: 14px 18px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .action-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 9px 14px;
        border-radius: 8px;
        border: 0.5px solid rgba(0,0,0,0.2);
        background: transparent;
        font-size: 13px;
        color: #1a1a18;
        cursor: pointer;
        text-align: left;
        transition: background 0.15s;
        text-decoration: none;
        width: 100%;
    }

        .action-btn:hover {
            background: #f5f5f3;
            text-decoration: none;
            color: #1a1a18;
        }

        .action-btn.primary {
            background: #185FA5;
            color: #fff;
            border-color: #185FA5;
        }

            .action-btn.primary:hover {
                background: #0C447C;
                color: #fff;
            }

    .action-icon {
        width: 20px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

    .text-muted-sm {
        color: #888780;
    }

    .fw-med {
        font-weight: 500;
    }

    .danger-title {
        color: #A32D2D;
    }
</style>

<div class="db-wrap">

    <div class="db-header">
        <div class="db-title">ড্যাশবোর্ড</div>
        <div class="db-date" id="dbDateDisplay">লোড হচ্ছে...</div>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-icon icon-blue">📦</div>
            <div>
                <div class="stat-label">মোট প্রোডাক্ট</div>
                <div class="stat-value">@Model.TotalProducts</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon icon-green">🧾</div>
            <div>
                <div class="stat-label">মোট অর্ডার</div>
                <div class="stat-value">@Model.TotalOrders</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon icon-amber">👥</div>
            <div>
                <div class="stat-label">মোট ইউজার</div>
                <div class="stat-value">@Model.TotalUsers</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon icon-coral">💰</div>
            <div>
                <div class="stat-label">মোট আয়</div>
                <div class="stat-value">৳@Model.TotalRevenue.ToString("N0")</div>
            </div>
        </div>
    </div>

    <div class="main-grid">

        <div class="db-card">
            <div class="card-head">
                <span class="card-head-title">সাম্প্রতিক অর্ডার</span>
                <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn-sm">সব দেখুন →</a>
            </div>
            <div class="tbl-wrap">
                <table class="db-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>ইউজার</th>
                            <th>তারিখ</th>
                            <th>পরিমাণ</th>
                            <th>স্ট্যাটাস</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.RecentOrders)
                        {
                            <tr>
                                <td class="fw-med">#@order.Id</td>
                                <td>@order.User?.FullName</td>
                                <td class="text-muted-sm">@order.OrderDate.ToString("dd MMM, hh:mm tt")</td>
                                <td class="fw-med">৳@order.TotalAmount.ToString("N0")</td>
                                <td>
                                    <span class="badge badge-status-@order.Status">@order.Status</span>
                                </td>
                                <td>
                                    <a asp-area="Admin" asp-controller="Order" asp-action="Detail"
                                       asp-route-id="@order.Id" class="eye-btn" title="বিস্তারিত">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!Model.RecentOrders.Any())
                        {
                            <tr>
                                <td colspan="6" style="text-align:center; color:#888780; padding: 2rem;">
                                    কোনো অর্ডার নেই
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="right-col">

            @if (Model.PendingOrders > 0)
            {
                <div class="alert-warn">
                    <div class="alert-icon">⚠️</div>
                    <div class="alert-text">
                        <div class="alert-title">@Model.PendingOrders টি পেন্ডিং অর্ডার</div>
                        <div class="alert-sub">দ্রুত প্রসেস করুন</div>
                    </div>
                    <a asp-area="Admin" asp-controller="Order" asp-action="Index"
                       asp-route-status="Pending" class="btn-warn">দেখুন</a>
                </div>
            }

            @if (Model.LowStockItems.Any())
            {
                <div class="db-card">
                    <div class="card-head">
                        <span class="card-head-title danger-title">⚠ কম স্টক</span>
                    </div>
                    <ul class="stock-list">
                        @foreach (var p in Model.LowStockItems)
                        {
                            <li class="stock-item">
                                <span class="stock-name">@p.Name</span>
                                <span class="badge @(p.Stock == 0 ? "badge-out" : "badge-low")">
                                    @(p.Stock == 0 ? "শেষ" : $"{p.Stock} বাকি")
                                </span>
                            </li>
                        }
                    </ul>
                    <div class="card-foot">
                        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn-sm">
                            প্রোডাক্ট ম্যানেজ করুন
                        </a>
                    </div>
                </div>
            }

            <div class="db-card">
                <div class="card-head">
                    <span class="card-head-title">দ্রুত অ্যাকশন</span>
                </div>
                <div class="action-grid">
                    <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="action-btn primary">
                        <span class="action-icon">+</span>
                        নতুন প্রোডাক্ট যোগ করুন
                    </a>
                    <a asp-area="Admin" asp-controller="Category" asp-action="Create" class="action-btn">
                        <span class="action-icon">🗂</span>
                        নতুন ক্যাটাগরি যোগ করুন
                    </a>
                    <a asp-area="Admin" asp-controller="Slider" asp-action="Create" class="action-btn">
                        <span class="action-icon">🖼</span>
                        নতুন স্লাইডার যোগ করুন
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const now = new Date();
        const bn = ['জানুয়ারি','ফেব্রুয়ারি','মার্চ','এপ্রিল','মে','জুন','জুলাই','আগস্ট','সেপ্টেম্বর','অক্টোবর','নভেম্বর','ডিসেম্বর'];
        const days = ['রবিবার','সোমবার','মঙ্গলবার','বুধবার','বৃহস্পতিবার','শুক্রবার','শনিবার'];
        document.getElementById('dbDateDisplay').textContent =
            days[now.getDay()] + ', ' + now.getDate() + ' ' + bn[now.getMonth()] + ' ' + now.getFullYear();
    </script>
}
