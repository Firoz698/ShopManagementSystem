@model List<ShopManagementSystem.Models.Category>
@{ ViewData["Title"] = "ক্যাটাগরি ম্যানেজমেন্ট"; }

<div class="d-flex justify-content-end mb-4">
    <a asp-action="Create" class="btn btn-dark">
        <i class="bi bi-plus-circle me-2"></i>নতুন ক্যাটাগরি
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>ছবি</th>
                    <th>নাম</th>
                    <th>স্লাগ</th>
                    <th class="text-center">প্রোডাক্ট সংখ্যা</th>
                    <th class="text-center">স্ট্যাটাস</th>
                    <th class="text-center">অ্যাকশন</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(cat.ImageUrl))
                            {
                                <img src="@cat.ImageUrl" class="rounded-circle"
                                     style="width:42px;height:42px;object-fit:cover"
                                     onerror="this.src='https://via.placeholder.com/42'" />
                            }
                            else
                            {
                                <div class="rounded-circle bg-warning d-flex align-items-center justify-content-center"
                                     style="width:42px;height:42px">
                                    <i class="bi bi-grid text-dark"></i>
                                </div>
                            }
                        </td>
                        <td class="fw-semibold">@cat.Name</td>
                        <td><code class="small">@cat.Slug</code></td>
                        <td class="text-center">
                            <span class="badge bg-primary rounded-pill">@cat.Products.Count</span>
                        </td>
                        <td class="text-center">
                            <span class="badge @(cat.IsActive ? "bg-success" : "bg-secondary") rounded-pill px-3">
                                @(cat.IsActive ? "সক্রিয়" : "নিষ্ক্রিয়")
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@cat.Id" method="post"
                                      onsubmit="return confirm('ক্যাটাগরিটি মুছবেন?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-5">কোনো ক্যাটাগরি নেই</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
