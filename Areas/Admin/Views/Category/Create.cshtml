@model ShopManagementSystem.Models.Category
@{ ViewData["Title"] = "নতুন ক্যাটাগরি"; }

<div class="card border-0 shadow-sm" style="max-width:600px">
    <div class="card-body p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-medium">ক্যাটাগরির নাম <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="যেমন: Electronics" required />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label fw-medium">ক্যাটাগরি ছবি</label>
                <input type="file" name="image" class="form-control" accept="image/*"
                       onchange="document.getElementById('catPreview').src=URL.createObjectURL(this.files[0])" />
                <img id="catPreview" src="#" class="mt-2 rounded" style="width:80px;height:80px;object-fit:cover;display:none"
                     onload="this.style.display='block'" />
            </div>
            <div class="form-check form-switch mb-4">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                <label asp-for="IsActive" class="form-check-label fw-medium">সক্রিয়</label>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4">
                    <i class="bi bi-check-circle me-2"></i>সেভ করুন
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">বাতিল</a>
            </div>
        </form>
    </div>
</div>
