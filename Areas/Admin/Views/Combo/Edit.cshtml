@model ShopManagementSystem.ViewModels.ComboCreateViewModel
@{
    ViewData["Title"] = "কম্বো অফার সম্পাদনা";
    var products = ViewBag.Products as List<ShopManagementSystem.Models.Product>;
    var existingBanner = ViewBag.ExistingBanner as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i>কম্বো সম্পাদনা</h5>
        <small class="text-muted">কম্বো অফারের তথ্য পরিবর্তন করুন</small>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>ফিরে যান
    </a>
</div>

<form asp-action="Edit" enctype="multipart/form-data" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" id="validationSummary"></div>

    <div class="row g-4">
        <!-- Left Column: Basic Info -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-info-circle me-2 text-primary"></i>মূল তথ্য</h6>
                </div>
                <div class="card-body p-4">
                    <!-- Title -->
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-medium">শিরোনাম <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" placeholder="যেমন: পরিবার প্যাকেজ" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-medium">বিবরণ</label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="কম্বো অফারের সংক্ষিপ্ত বিবরণ লিখুন..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <!-- Prices -->
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label asp-for="ComboPrice" class="form-label fw-medium">কম্বো মূল্য (৳) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">৳</span>
                                <input asp-for="ComboPrice" type="number" step="0.01" class="form-control" placeholder="০.০০" />
                            </div>
                            <span asp-validation-for="ComboPrice" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label fw-medium">সর্ট ক্রম</label>
                            <input asp-for="SortOrder" type="number" class="form-control" placeholder="০" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Date & Status -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-calendar3 me-2 text-primary"></i>মেয়াদ ও অবস্থা</h6>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label asp-for="StartDate" class="form-label fw-medium">শুরুর তারিখ</label>
                            <input asp-for="StartDate" type="datetime-local" class="form-control"
                                   value="@(Model.StartDate?.ToString("yyyy-MM-ddTHH:mm"))" />
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="EndDate" class="form-label fw-medium">শেষের তারিখ</label>
                            <input asp-for="EndDate" type="datetime-local" class="form-control"
                                   value="@(Model.EndDate?.ToString("yyyy-MM-ddTHH:mm"))" />
                        </div>
                    </div>

                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsActive" class="form-check-label fw-medium">
                            সক্রিয় রাখুন
                        </label>
                    </div>
                </div>
            </div>

            <!-- Banner Image -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-image me-2 text-primary"></i>ব্যানার ছবি</h6>
                </div>
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(existingBanner))
                    {
                        <div class="mb-3 position-relative d-inline-block">
                            <img src="@existingBanner" class="img-thumbnail rounded-3"
                                 style="height:130px;object-fit:cover;max-width:100%" alt="বর্তমান ব্যানার" />
                            <span class="badge bg-dark position-absolute top-0 start-0 m-1" style="font-size:10px">বর্তমান</span>
                        </div>
                    }

                    <div>
                        <label asp-for="BannerImage" class="form-label fw-medium">
                            @(string.IsNullOrEmpty(existingBanner) ? "ছবি আপলোড করুন" : "নতুন ছবি (পরিবর্তন করতে চাইলে)")
                        </label>
                        <input asp-for="BannerImage" type="file" class="form-control" accept="image/*"
                               id="bannerInput" onchange="previewBanner(this)" />
                        <div class="mt-2">
                            <img id="bannerPreview" src="#" alt="প্রিভিউ"
                                 class="img-thumbnail rounded-3 d-none"
                                 style="height:130px;object-fit:cover;max-width:100%" />
                        </div>
                        <small class="text-muted">JPG, PNG বা WebP। সর্বোচ্চ ২ MB।</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Products -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-auto">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-box-seam me-2 text-primary"></i>পণ্য নির্বাচন</h6>
                    <button type="button" class="btn btn-sm btn-dark" onclick="addProductRow()">
                        <i class="bi bi-plus me-1"></i>পণ্য যোগ করুন
                    </button>
                </div>
                <div class="card-body p-3">
                    <div id="productRows">
                        @if (Model.Products != null && Model.Products.Any())
                        {
                            for (int i = 0; i < Model.Products.Count; i++)
                            {
                                var entry = Model.Products[i];
                                <div class="product-row border rounded-3 p-3 mb-2 bg-light">
                                    <div class="d-flex gap-2 align-items-start">
                                        <div class="flex-grow-1">
                                            <label class="form-label small fw-medium mb-1">পণ্য</label>
                                            <select name="Products[@i].ProductId"
                                                    class="form-select form-select-sm product-select"
                                                    onchange="updateRowPreview(this)">
                                                <option value="0">-- পণ্য বেছে নিন --</option>
                                                @foreach (var p in products)
                                                {
                                                    var imgUrl = p.Images?.FirstOrDefault(img => img.IsPrimary)?.ImageUrl
                                                                 ?? p.Images?.FirstOrDefault()?.ImageUrl ?? "";
                                                    <option value="@p.Id"
                                                            data-price="@p.Price"
                                                            data-img="@imgUrl"
                                                    @@(entry.ProductId == p.Id ? "selected" : "")>
                                                        @p.Name — ৳@p.Price.ToString("N0")
                                                    </option>
                                                }
                                            </select>
                                        </div>
                                        <div style="width:75px">
                                            <label class="form-label small fw-medium mb-1">পরিমাণ</label>
                                            <input type="number" name="Products[@i].Quantity"
                                                   class="form-control form-control-sm qty-input"
                                                   value="@entry.Quantity" min="1" max="99"
                                                   onchange="recalcTotal()" />
                                        </div>
                                        <div class="pt-4">
                                            <button type="button" class="btn btn-sm btn-outline-danger"
                                                    onclick="removeRow(this)" title="সরান">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <!-- mini product preview -->
                                    <div class="row-preview mt-2 d-none">
                                        <div class="d-flex align-items-center gap-2 p-2 bg-white rounded-2 border">
                                            <img class="preview-img rounded" src="#"
                                                 style="width:40px;height:40px;object-fit:cover" alt="" />
                                            <span class="preview-price small text-muted"></span>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <!-- empty placeholder row -->
                            <div class="product-row border rounded-3 p-3 mb-2 bg-light">
                                <div class="d-flex gap-2 align-items-start">
                                    <div class="flex-grow-1">
                                        <label class="form-label small fw-medium mb-1">পণ্য</label>
                                        <select name="Products[0].ProductId"
                                                class="form-select form-select-sm product-select"
                                                onchange="updateRowPreview(this)">
                                            <option value="0">-- পণ্য বেছে নিন --</option>
                                            @foreach (var p in products)
                                            {
                                                var imgUrl = p.Images?.FirstOrDefault(img => img.IsPrimary)?.ImageUrl
                                                             ?? p.Images?.FirstOrDefault()?.ImageUrl ?? "";
                                                <option value="@p.Id"
                                                        data-price="@p.Price"
                                                        data-img="@imgUrl">
                                                    @p.Name — ৳@p.Price.ToString("N0")
                                                </option>
                                            }
                                        </select>
                                    </div>
                                    <div style="width:75px">
                                        <label class="form-label small fw-medium mb-1">পরিমাণ</label>
                                        <input type="number" name="Products[0].Quantity"
                                               class="form-control form-control-sm qty-input"
                                               value="1" min="1" max="99"
                                               onchange="recalcTotal()" />
                                    </div>
                                    <div class="pt-4">
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                onclick="removeRow(this)" title="সরান">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="row-preview mt-2 d-none">
                                    <div class="d-flex align-items-center gap-2 p-2 bg-white rounded-2 border">
                                        <img class="preview-img rounded" src="#"
                                             style="width:40px;height:40px;object-fit:cover" alt="" />
                                        <span class="preview-price small text-muted"></span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Estimated savings -->
                    <div class="mt-3 p-3 rounded-3 bg-success bg-opacity-10 border border-success border-opacity-25">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small fw-medium text-success"><i class="bi bi-tag me-1"></i>অনুমানিত মূল মূল্য</span>
                            <span class="fw-bold text-success" id="originalTotal">৳০</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-1">
                            <span class="small text-muted">কম্বো মূল্য দিলে সাশ্রয়</span>
                            <span class="fw-bold text-danger" id="savingsDisplay">—</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="d-flex gap-2 justify-content-end mt-4 pb-4">
        <a asp-action="Index" class="btn btn-outline-secondary px-4">
            <i class="bi bi-x me-1"></i>বাতিল
        </a>
        <button type="submit" class="btn btn-dark px-5">
            <i class="bi bi-floppy me-2"></i>পরিবর্তন সংরক্ষণ করুন
        </button>
    </div>
</form>

<!-- Hidden template for new product rows -->
<template id="productRowTemplate">
    <div class="product-row border rounded-3 p-3 mb-2 bg-light">
        <div class="d-flex gap-2 align-items-start">
            <div class="flex-grow-1">
                <label class="form-label small fw-medium mb-1">পণ্য</label>
                <select name="Products[__INDEX__].ProductId"
                        class="form-select form-select-sm product-select"
                        onchange="updateRowPreview(this)">
                    <option value="0">-- পণ্য বেছে নিন --</option>
                    @foreach (var p in products)
                    {
                        var imgUrl = p.Images?.FirstOrDefault(img => img.IsPrimary)?.ImageUrl
                                     ?? p.Images?.FirstOrDefault()?.ImageUrl ?? "";
                        <option value="@p.Id"
                                data-price="@p.Price"
                                data-img="@imgUrl">
                            @p.Name — ৳@p.Price.ToString("N0")
                        </option>
                    }
                </select>
            </div>
            <div style="width:75px">
                <label class="form-label small fw-medium mb-1">পরিমাণ</label>
                <input type="number" name="Products[__INDEX__].Quantity"
                       class="form-control form-control-sm qty-input"
                       value="1" min="1" max="99"
                       onchange="recalcTotal()" />
            </div>
            <div class="pt-4">
                <button type="button" class="btn btn-sm btn-outline-danger"
                        onclick="removeRow(this)" title="সরান">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
        <div class="row-preview mt-2 d-none">
            <div class="d-flex align-items-center gap-2 p-2 bg-white rounded-2 border">
                <img class="preview-img rounded" src="#"
                     style="width:40px;height:40px;object-fit:cover" alt="" />
                <span class="preview-price small text-muted"></span>
            </div>
        </div>
    </div>
</template>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        // ── Banner preview ──────────────────────────────────────────
        function previewBanner(input) {
            const preview = document.getElementById('bannerPreview');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // ── Add product row ─────────────────────────────────────────
        function addProductRow() {
            const container = document.getElementById('productRows');
            const rows = container.querySelectorAll('.product-row');
            const index = rows.length;
            const template = document.getElementById('productRowTemplate').innerHTML;
            const html = template.replaceAll('__INDEX__', index);
            const wrapper = document.createElement('div');
            wrapper.innerHTML = html;
            container.appendChild(wrapper.firstElementChild);
            recalcTotal();
        }

        // ── Remove product row ──────────────────────────────────────
        function removeRow(btn) {
            btn.closest('.product-row').remove();
            reIndexRows();
            recalcTotal();
        }

        // ── Re-index name attributes after removal ──────────────────
        function reIndexRows() {
            const rows = document.querySelectorAll('.product-row');
            rows.forEach((row, i) => {
                const sel = row.querySelector('.product-select');
                const qty = row.querySelector('.qty-input');
                if (sel) sel.name = `Products[${i}].ProductId`;
                if (qty) qty.name = `Products[${i}].Quantity`;
            });
        }

        // ── Show mini product preview ───────────────────────────────
        function updateRowPreview(sel) {
            const row = sel.closest('.product-row');
            const preview = row.querySelector('.row-preview');
            const img = row.querySelector('.preview-img');
            const priceSpan = row.querySelector('.preview-price');
            const chosen = sel.options[sel.selectedIndex];
            const imgUrl = chosen.getAttribute('data-img');
            const price = chosen.getAttribute('data-price');

            if (sel.value !== '0' && imgUrl) {
                img.src = imgUrl;
                priceSpan.textContent = '৳' + parseFloat(price).toLocaleString('bn-BD');
                preview.classList.remove('d-none');
            } else {
                preview.classList.add('d-none');
            }
            recalcTotal();
        }

        // ── Recalculate original total & savings ─────────────────────
        function recalcTotal() {
            let total = 0;
            document.querySelectorAll('.product-row').forEach(row => {
                const sel = row.querySelector('.product-select');
                const qty = parseInt(row.querySelector('.qty-input')?.value) || 1;
                if (sel && sel.value !== '0') {
                    const price = parseFloat(sel.options[sel.selectedIndex].getAttribute('data-price')) || 0;
                    total += price * qty;
                }
            });

            document.getElementById('originalTotal').textContent =
                '৳' + Math.round(total).toLocaleString('en-BD');

            const comboInput = document.querySelector('input[name="ComboPrice"]');
            const comboPrice = parseFloat(comboInput?.value) || 0;
            const savingsEl = document.getElementById('savingsDisplay');
            if (total > 0 && comboPrice > 0 && total > comboPrice) {
                const savings = total - comboPrice;
                savingsEl.textContent = '৳' + Math.round(savings).toLocaleString('en-BD') + ' সাশ্রয়';
                savingsEl.className = 'fw-bold text-danger';
            } else {
                savingsEl.textContent = '—';
                savingsEl.className = 'fw-bold text-muted';
            }
        }

        // ── Init existing rows preview & total ──────────────────────
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.product-select').forEach(sel => {
                if (sel.value !== '0') updateRowPreview(sel);
            });
            recalcTotal();

            // Recalc when combo price changes
            const comboInput = document.querySelector('input[name="ComboPrice"]');
            if (comboInput) comboInput.addEventListener('input', recalcTotal);
        });
    </script>
}
