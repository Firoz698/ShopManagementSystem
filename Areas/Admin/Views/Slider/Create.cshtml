@model ShopManagementSystem.Models.Slider
@{ ViewData["Title"] = "নতুন স্লাইডার যোগ করুন"; }

<div class="card border-0 shadow-sm" style="max-width:680px">
    <div class="card-body p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-medium">স্লাইডার ছবি <span class="text-danger">*</span></label>
                <input type="file" name="image" class="form-control" accept="image/*" required
                       onchange="document.getElementById('sliderPreview').src=URL.createObjectURL(this.files[0]);document.getElementById('sliderPreview').style.display='block'" />
                <img id="sliderPreview" src="#" class="mt-2 rounded w-100"
                     style="height:200px;object-fit:cover;display:none" />
                <div class="form-text">প্রস্তাবিত আকার: ১৪০০ × ৫০০ পিক্সেল</div>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-medium small">টাইটেল</label>
                    <input asp-for="Title" class="form-control" placeholder="স্লাইডারের শিরোনাম" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-medium small">সাব-টাইটেল</label>
                    <input asp-for="SubTitle" class="form-control" placeholder="উপশিরোনাম" />
                </div>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-medium small">বাটনের লেখা</label>
                    <input asp-for="ButtonText" class="form-control" placeholder="যেমন: Shop Now" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-medium small">বাটনের লিংক</label>
                    <input asp-for="ButtonUrl" class="form-control" placeholder="/Product" />
                </div>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-medium small">সাজানোর ক্রম</label>
                    <input asp-for="SortOrder" type="number" min="0" class="form-control" value="0" />
                </div>
            </div>
            <div class="form-check form-switch mb-4">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                <label asp-for="IsActive" class="form-check-label fw-medium">সক্রিয়</label>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4">
                    <i class="bi bi-check-circle me-2"></i>সেভ করুন
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">বাতিল</a>
            </div>
        </form>
    </div>
</div>
