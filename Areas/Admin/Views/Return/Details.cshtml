@model ShopManagementSystem.Models.ReturnRequest
@{
    ViewData["Title"] = $"রিটার্ন রিকোয়েস্ট #{Model.Id}";
    var statusColor = Model.Status switch
    {
        "Approved" => "success",
        "Rejected" => "danger",
        _ => "warning"
    };
    var statusBg = Model.Status switch
    {
        "Approved" => "#d1fae5",
        "Rejected" => "#fee2e2",
        _ => "#fef3c7"
    };
    var statusText = Model.Status switch
    {
        "Approved" => "#065f46",
        "Rejected" => "#991b1b",
        _ => "#92400e"
    };
    var productImg = Model.Product?.Images?.FirstOrDefault(i => i.IsPrimary)?.ImageUrl
                  ?? Model.Product?.Images?.FirstOrDefault()?.ImageUrl;
}

<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-arrow-return-left me-2 text-muted"></i>রিটার্ন রিকোয়েস্ট #@Model.Id
        </h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Return" asp-action="Index">রিটার্ন লিস্ট</a></li>
                <li class="breadcrumb-item active">#@Model.Id</li>
            </ol>
        </nav>
    </div>
    <span class="badge rounded-pill px-3 py-2 fs-6 fw-medium"
          style="background:@statusBg;color:@statusText">
        @Model.Status
    </span>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-2 small mb-3">
        <i class="bi bi-check-circle me-1"></i>@TempData["Success"]
        <button type="button" class="btn-close py-2" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">

    <!-- ── বাম কলাম ──────────────────────────────────────────────────────── -->
    <div class="col-lg-8">

        <!-- Customer Info -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold border-bottom py-3">
                <i class="bi bi-person-circle me-2 text-muted"></i>কাস্টমার তথ্য
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="text-muted small mb-1">নাম</div>
                        <div class="fw-medium">@Model.User?.FullName</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted small mb-1">ইমেইল</div>
                        <div class="fw-medium">@Model.User?.Email</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted small mb-1">ফোন</div>
                        <div class="fw-medium">@(Model.User?.PhoneNumber ?? "—")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted small mb-1">রিকোয়েস্ট তারিখ</div>
                        <div class="fw-medium">@Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Info -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold border-bottom py-3">
                <i class="bi bi-box-seam me-2 text-muted"></i>পণ্যের তথ্য
            </div>
            <div class="card-body">
                <div class="d-flex gap-3 align-items-center">
                    @if (!string.IsNullOrEmpty(productImg))
                    {
                        <img src="@productImg"
                             style="width:80px;height:80px;object-fit:cover;border-radius:8px"
                             onerror="this.src='https://via.placeholder.com/80x80/f8f9fa/6c757d?text=No+Image'"
                             alt="@Model.Product?.Name" />
                    }
                    else
                    {
                        <div style="width:80px;height:80px;background:#f8f9fa;border-radius:8px;display:flex;align-items:center;justify-content:center">
                            <i class="bi bi-image text-muted fs-4"></i>
                        </div>
                    }
                    <div>
                        <div class="fw-semibold">@Model.Product?.Name</div>
                        <div class="text-muted small mt-1">প্রোডাক্ট ID: #@Model.ProductId</div>
                        <a asp-area="Admin" asp-controller="Product" asp-action="Edit"
                           asp-route-id="@Model.ProductId"
                           class="btn btn-outline-secondary btn-sm mt-2" style="font-size:.75rem">
                            <i class="bi bi-eye me-1"></i>পণ্য দেখুন
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Return Reason -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold border-bottom py-3">
                <i class="bi bi-chat-left-text me-2 text-muted"></i>রিটার্নের কারণ
            </div>
            <div class="card-body">
                <p class="mb-0 text-muted">@Model.Reason</p>
            </div>
        </div>

        <!-- Order Details -->
        @if (Model.Order != null)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold border-bottom py-3 d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-receipt me-2 text-muted"></i>সংশ্লিষ্ট অর্ডার #@Model.OrderId</span>
                    <a asp-area="Admin" asp-controller="Order" asp-action="Detail"
                       asp-route-id="@Model.OrderId"
                       class="btn btn-outline-dark btn-sm" style="font-size:.75rem">
                        <i class="bi bi-box-arrow-up-right me-1"></i>অর্ডার দেখুন
                    </a>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">পণ্য</th>
                                <th class="text-center">পরিমাণ</th>
                                <th class="text-end pe-3">মূল্য</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var od in Model.Order.OrderDetails)
                            {
                                <tr @(od.ProductId == Model.ProductId ? "class=table-warning" : "")>
                                    <td class="ps-3 small">
                                        @od.Product?.Name
                                        @if (od.ProductId == Model.ProductId)
                                        {
                                            <span class="badge bg-warning text-dark ms-1" style="font-size:.65rem">রিটার্ন পণ্য</span>
                                        }
                                    </td>
                                    <td class="text-center small">@od.Quantity</td>
                                    <td class="text-end pe-3 small fw-medium">৳@((od.UnitPrice * od.Quantity).ToString("N0"))</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="2" class="text-end fw-semibold ps-3">মোট:</td>
                                <td class="text-end pe-3 fw-bold">৳@Model.Order.TotalAmount.ToString("N0")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="card-footer bg-white small text-muted d-flex gap-3 flex-wrap">
                    <span><i class="bi bi-geo-alt me-1"></i>@Model.Order.ShippingAddress</span>
                    <span><i class="bi bi-telephone me-1"></i>@Model.Order.Phone</span>
                    <span><i class="bi bi-credit-card me-1"></i>@Model.Order.PaymentMethod</span>
                </div>
            </div>
        }
    </div>

    <!-- ── ডান কলাম ──────────────────────────────────────────────────────── -->
    <div class="col-lg-4">

        <!-- Admin Note (readonly if already decided) -->
        @if (!string.IsNullOrWhiteSpace(Model.AdminNote))
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold border-bottom py-3">
                    <i class="bi bi-shield-check me-2 text-muted"></i>অ্যাডমিন নোট
                </div>
                <div class="card-body">
                    <p class="mb-0 small text-muted">@Model.AdminNote</p>
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <div class="text-muted mt-2" style="font-size:.72rem">
                            আপডেট: @Model.UpdatedAt.Value.ToString("dd MMM yyyy, hh:mm tt")
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Action Card -->
        @if (Model.Status == "Pending")
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white fw-semibold border-bottom py-3">
                    <i class="bi bi-pencil-square me-2 text-muted"></i>সিদ্ধান্ত নিন
                </div>
                <div class="card-body">
                    <form asp-area="Admin" asp-controller="Return" asp-action="UpdateStatus" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="mb-3">
                            <label class="form-label fw-medium small">সিদ্ধান্ত</label>
                            <div class="d-flex gap-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="status" value="Approved" id="approve" checked />
                                    <label class="form-check-label text-success fw-medium small" for="approve">
                                        ✅ অনুমোদন
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio"
                                           name="status" value="Rejected" id="reject" />
                                    <label class="form-check-label text-danger fw-medium small" for="reject">
                                        ❌ প্রত্যাখ্যান
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-medium small">অ্যাডমিন নোট (ঐচ্ছিক)</label>
                            <textarea name="adminNote" class="form-control form-control-sm" rows="3"
                                  placeholder="ইউজারকে কারণ জানান..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-dark btn-sm w-100">
                            <i class="bi bi-check2-circle me-1"></i>সিদ্ধান্ত সেভ করুন
                        </button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <!-- Already decided -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body text-center py-4">
                    @if (Model.Status == "Approved")
                    {
                        <i class="bi bi-check-circle-fill text-success display-5 d-block mb-2"></i>
                        <div class="fw-semibold text-success">অনুমোদিত হয়েছে</div>
                    }
                    else
                    {
                        <i class="bi bi-x-circle-fill text-danger display-5 d-block mb-2"></i>
                        <div class="fw-semibold text-danger">প্রত্যাখ্যান করা হয়েছে</div>
                    }
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <div class="text-muted small mt-1">
                            @Model.UpdatedAt.Value.ToString("dd MMM yyyy")
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Quick Links -->
        <div class="card border-0 shadow-sm">
            <div class="card-body d-grid gap-2">
                <a asp-area="Admin" asp-controller="Return" asp-action="Index"
                   class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i>রিটার্ন লিস্টে ফিরুন
                </a>
                @if (Model.Order != null)
                {
                    <a asp-area="Admin" asp-controller="Order" asp-action="Detail"
                       asp-route-id="@Model.OrderId"
                       class="btn btn-outline-dark btn-sm">
                        <i class="bi bi-receipt me-1"></i>অর্ডার #@Model.OrderId দেখুন
                    </a>
                }
            </div>
        </div>
    </div>
</div>
