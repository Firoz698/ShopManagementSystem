@model List<ShopManagementSystem.Models.Wishlist>
@{ ViewData["Title"] = "উইশলিস্ট"; }

<div class="container my-4">
    <h4 class="fw-bold mb-4"><i class="bi bi-heart-fill text-danger me-2"></i>আমার উইশলিস্ট</h4>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-heart display-2 d-block mb-3 opacity-25"></i>
            <h5>উইশলিস্ট খালি</h5>
            <p class="small">পছন্দের পণ্যগুলো উইশলিস্টে সেভ করুন।</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-dark mt-2">প্রোডাক্ট দেখুন</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                var p    = item.Product!;
                var img  = p.Images.FirstOrDefault(i => i.IsPrimary)?.ImageUrl ?? p.Images.FirstOrDefault()?.ImageUrl;
                var price = p.DiscountPrice ?? p.Price;

                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm h-100 position-relative">
                        <!-- Remove button -->
                        <form asp-action="Remove" method="post" class="position-absolute top-0 end-0 m-2 z-1">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-light rounded-circle shadow-sm"
                                    title="সরান" onclick="return confirm('উইশলিস্ট থেকে সরাবেন?')">
                                <i class="bi bi-x text-danger"></i>
                            </button>
                        </form>

                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id">
                            <img src="@img" class="card-img-top product-thumb"
                                 onerror="this.src='https://via.placeholder.com/300x220/f8f9fa/6c757d?text=No+Image'"
                                 alt="@p.Name" />
                        </a>
                        <div class="card-body p-3">
                            <div class="small text-muted mb-1">@p.Category?.Name</div>
                            <h6 class="fw-semibold mb-2 product-title">
                                <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id"
                                   class="text-decoration-none text-dark">@p.Name</a>
                            </h6>
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-bold @(p.DiscountPrice.HasValue ? "text-danger" : "")">
                                    ৳@price.ToString("N0")
                                </span>
                                @if (p.DiscountPrice.HasValue)
                                {
                                    <span class="text-muted small text-decoration-line-through">৳@p.Price.ToString("N0")</span>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
                            @if (p.Stock > 0)
                            {
                                <form asp-controller="Cart" asp-action="Add" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@p.Id" />
                                    <button class="btn btn-dark btn-sm w-100">
                                        <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ করুন
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-sm w-100" disabled>স্টক নেই</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
