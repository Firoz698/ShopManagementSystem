@model HomeViewModel
@{
    ViewData["Title"] = "হোম";
}

<!-- ── Dynamic Slider ──────────────────────────────────────────────────────── -->
@if (Model.Sliders.Any())
{
    <div id="heroSlider" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="4000">
        <div class="carousel-indicators">
            @for (int i = 0; i < Model.Sliders.Count; i++)
            {
                <button type="button" data-bs-target="#heroSlider" data-bs-slide-to="@i"
                        class="@(i == 0 ? "active" : "")"></button>
            }
        </div>
        <div class="carousel-inner">
            @for (int i = 0; i < Model.Sliders.Count; i++)
            {
                var s = Model.Sliders[i];
                <div class="carousel-item @(i == 0 ? "active" : "")">
                    <img src="@s.ImageUrl" class="d-block w-100 slider-img" alt="@s.Title"
                         onerror="this.src='https://via.placeholder.com/1400x500/1a1a2e/fff?text=ShopMS'" />
                    @if (!string.IsNullOrEmpty(s.Title))
                    {
                        <div class="carousel-caption d-none d-md-block">
                            <h2 class="fw-bold display-5 text-shadow">@s.Title</h2>
                            @if (!string.IsNullOrEmpty(s.SubTitle))
                            {
                                <p class="fs-5">@s.SubTitle</p>
                            }
                            @if (!string.IsNullOrEmpty(s.ButtonText))
                            {
                                <a href="@(s.ButtonUrl ?? "#")" class="btn btn-warning btn-lg mt-2 px-4 fw-semibold">
                                    @s.ButtonText <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            }
                        </div>
                    }
                </div>
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroSlider" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroSlider" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
}

<div class="container my-5">

    <!-- ── Categories ──────────────────────────────────────────────────────── -->
    @if (Model.Categories.Any())
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold mb-0">ক্যাটাগরি</h4>
            <a asp-controller="Product" asp-action="Index" class="btn btn-sm btn-outline-dark">সব দেখুন</a>
        </div>
        <div class="row g-3 mb-5">
            @foreach (var cat in Model.Categories)
            {
                <div class="col-6 col-md-3 col-lg-2">
                    <a href="/Product?categoryId=@cat.Id" class="text-decoration-none">
                        <div class="card category-card text-center h-100 border-0 shadow-sm">
                            <div class="card-body py-3">
                                @if (!string.IsNullOrEmpty(cat.ImageUrl))
                                {
                                    <img src="@cat.ImageUrl" class="rounded-circle mb-2"
                                         style="width:60px;height:60px;object-fit:cover"
                                         onerror="this.style.display='none'" alt="@cat.Name" />
                                }
                                else
                                {
                                    <div class="bg-warning rounded-circle d-inline-flex align-items-center
                                                            justify-content-center mb-2" style="width:60px;height:60px">
                                        <i class="bi bi-grid fs-4 text-dark"></i>
                                    </div>
                                }
                                <div class="fw-semibold small">@cat.Name</div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }

    <!-- ── Feature Banners ─────────────────────────────────────────────────── -->
    <div class="row g-3 mb-5">
        <div class="col-md-4">
            <div class="p-3 rounded-3 text-center bg-primary bg-opacity-10 border border-primary border-opacity-25">
                <i class="bi bi-truck fs-2 text-primary"></i>
                <div class="fw-semibold mt-1">দ্রুত ডেলিভারি</div>
                <small class="text-muted">ঢাকায় ১-২ দিন, বাইরে ৩-৫ দিন</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 rounded-3 text-center bg-success bg-opacity-10 border border-success border-opacity-25">
                <i class="bi bi-shield-check fs-2 text-success"></i>
                <div class="fw-semibold mt-1">১০০% অরিজিনাল</div>
                <small class="text-muted">গ্যারান্টিযুক্ত পণ্য</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 rounded-3 text-center bg-warning bg-opacity-10 border border-warning border-opacity-25">
                <i class="bi bi-arrow-counterclockwise fs-2 text-warning"></i>
                <div class="fw-semibold mt-1">সহজ রিটার্ন</div>
                <small class="text-muted">৭ দিনের মধ্যে</small>
            </div>
        </div>
    </div>

    <!-- ── New Arrivals ─────────────────────────────────────────────────────── -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0">নতুন পণ্য</h4>
        <a asp-controller="Product" asp-action="Index" class="btn btn-sm btn-outline-dark">সব দেখুন</a>
    </div>

    <div class="row g-3">
        @foreach (var p in Model.Products)
        {
            var img = p.Images.FirstOrDefault(i => i.IsPrimary)?.ImageUrl ?? p.Images.FirstOrDefault()?.ImageUrl;
            var hasSizes = p.Sizes.Any(s => s.IsActive && s.Stock > 0);
            var minPrice = hasSizes ? p.Sizes.Where(s => s.IsActive && s.Stock > 0).Min(s => s.SalesPrice) : (p.DiscountPrice ?? p.Price);

            <div class="col-6 col-md-4 col-lg-3">
                <div class="card product-card h-100 border-0 shadow-sm">
                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id">
                        <img src="@img" class="card-img-top product-thumb"
                             onerror="this.src='https://via.placeholder.com/300x220/f8f9fa/6c757d?text=No+Image'"
                             alt="@p.Name" />
                    </a>
                    @if (p.DiscountPrice.HasValue)
                    {
                        <span class="badge bg-danger position-absolute top-0 end-0 m-2">Sale</span>
                    }
                    <div class="card-body p-3">
                        <div class="small text-muted mb-1">@p.Category?.Name</div>
                        <h6 class="card-title fw-semibold mb-2 product-title">
                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id"
                               class="text-decoration-none text-dark">@p.Name</a>
                        </h6>
                        <div class="d-flex align-items-center gap-2">
                            @if (hasSizes)
                            {
                                <span class="fw-bold text-dark">৳@minPrice.ToString("N0") থেকে</span>
                            }
                            else if (p.DiscountPrice.HasValue)
                            {
                                <span class="fw-bold text-danger">৳@p.DiscountPrice.Value.ToString("N0")</span>
                                <span class="text-muted small text-decoration-line-through">৳@p.Price.ToString("N0")</span>
                            }
                            else
                            {
                                <span class="fw-bold text-dark">৳@p.Price.ToString("N0")</span>
                            }
                        </div>
                        @if (p.Stock == 0 && !hasSizes)
                        {
                            <span class="badge bg-secondary mt-1">স্টক শেষ</span>
                        }
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
                        @if (p.Stock > 0 || hasSizes)
                        {
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @if (hasSizes)
                                {
                                    <!-- Size আছে → Detail page এ যাবে -->
                                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id"
                                       class="btn btn-dark btn-sm w-100">
                                        <i class="bi bi-eye me-1"></i>সাইজ দেখুন
                                    </a>
                                }
                                else
                                {
                                    <!-- Size নেই → Ajax Add to Cart -->
                                    <button class="btn btn-dark btn-sm w-100"
                                            onclick="quickAddToCart(@p.Id, this)">
                                        <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ
                                    </button>
                                }
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Login"
                                   class="btn btn-dark btn-sm w-100">
                                    <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ
                                </a>
                            }
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-sm w-100" disabled>স্টক নেই</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- ── Cart Success Toast ─────────────────────────────────────────────────── -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999">
    <div id="cartToast" class="toast align-items-center text-bg-success border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body fw-medium">
                <i class="bi bi-check-circle me-2"></i>কার্টে যোগ হয়েছে!
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // CSRF token
        const _token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        // Quick Add to Cart (no size, from home/list page)
        function quickAddToCart(productId, btnEl) {
            if (btnEl) {
                btnEl.disabled = true;
                btnEl.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>';
            }

            var formData = new FormData();
            formData.append('productId', productId);
            formData.append('quantity',  1);
            formData.append('__RequestVerificationToken', _token);

            fetch('/Cart/AddAjax', { method: 'POST', body: formData })
            .then(function(res) { return res.json(); })
            .then(function(data) {
                if (data.success) {
                    // Cart badge update
                    updateCartBadge(data.cartCount);

                    // Toast show
                    var toastEl = document.getElementById('cartToast');
                    var toast   = new bootstrap.Toast(toastEl, { delay: 2500 });
                    toast.show();
                } else {
                    alert(data.message || 'কার্টে যোগ করা যায়নি।');
                }
                if (btnEl) {
                    btnEl.disabled = false;
                    btnEl.innerHTML = '<i class="bi bi-cart-plus me-1"></i>কার্টে যোগ';
                }
            })
            .catch(function() {
                if (btnEl) {
                    btnEl.disabled = false;
                    btnEl.innerHTML = '<i class="bi bi-cart-plus me-1"></i>কার্টে যোগ';
                }
            });
        }

        // Cart badge update in navbar
        function updateCartBadge(count) {
            var badge = document.querySelector('.navbar .badge.rounded-pill');
            if (badge) {
                badge.textContent = count;
            } else {
                var cartLink = document.querySelector('a[href="/Cart"]');
                if (cartLink) {
                    cartLink.style.position = 'relative';
                    var sp = document.createElement('span');
                    sp.className   = 'position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark';
                    sp.textContent = count;
                    cartLink.appendChild(sp);
                }
            }
        }
    </script>
}
