@model HomeViewModel
@{
    ViewData["Title"] = "হোম";
}

<style>
    /* ── HERO SLIDER ── */
    .hero-slider-wrap {
        position: relative;
        overflow: hidden;
        background: #1A1235;
    }

        .hero-slider-wrap .carousel-item {
            height: clamp(260px, 52vw, 520px);
        }

    .slider-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        opacity: 0.82;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(26,18,53,0.78) 0%, rgba(78,38,192,0.35) 60%, transparent 100%);
        pointer-events: none;
    }

    .carousel-caption {
        left: 5%;
        right: 35%;
        bottom: auto;
        top: 50%;
        transform: translateY(-50%);
        text-align: left;
        padding: 0;
    }

        .carousel-caption h2 {
            font-size: clamp(1.3rem, 4vw, 2.8rem);
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 0.6rem;
            text-shadow: 0 2px 12px rgba(0,0,0,0.4);
        }

        .carousel-caption p {
            font-size: clamp(0.85rem, 2vw, 1.1rem);
            opacity: 0.88;
            margin-bottom: 1.1rem;
        }

    .btn-hero {
        background: linear-gradient(135deg, #FF7A2F, #FF4F81);
        border: none;
        color: #fff;
        border-radius: 50px;
        padding: 0.6rem 1.8rem;
        font-weight: 600;
        font-size: 0.95rem;
        box-shadow: 0 4px 18px rgba(255,79,129,0.45);
        transition: transform 0.18s, opacity 0.18s;
    }

        .btn-hero:hover {
            transform: translateY(-2px);
            opacity: 0.92;
            color: #fff;
        }

    .carousel-indicators [data-bs-target] {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(255,255,255,0.45);
        border: none;
        transition: background 0.2s, width 0.25s;
    }

    .carousel-indicators .active {
        background: #FF7A2F;
        width: 24px;
        border-radius: 4px;
    }

    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        background-color: rgba(255,255,255,0.15);
        border-radius: 50%;
        width: 38px;
        height: 38px;
        background-size: 50%;
        backdrop-filter: blur(4px);
    }

    /* ── SECTION HEADER ── */
    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

    .section-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #1A1235;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-title-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6C3EE8, #FF4F81);
        flex-shrink: 0;
    }

    .btn-see-all {
        font-size: 0.82rem;
        font-weight: 600;
        color: #6C3EE8;
        border: 1.5px solid rgba(108,62,232,0.3);
        border-radius: 50px;
        padding: 0.28rem 1rem;
        text-decoration: none;
        transition: background 0.18s, color 0.18s;
    }

        .btn-see-all:hover {
            background: #6C3EE8;
            color: #fff;
        }

    /* ── CATEGORY CARDS ── */
    .cat-card {
        background: #fff;
        border-radius: 16px;
        border: 1.5px solid rgba(108,62,232,0.10);
        padding: 1rem 0.5rem;
        text-align: center;
        text-decoration: none;
        color: #1A1235;
        display: block;
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    }

        .cat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(108,62,232,0.15);
            border-color: rgba(108,62,232,0.35);
            color: #6C3EE8;
        }

    .cat-icon-wrap {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        margin: 0 auto 0.6rem;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #EDE8FF, #FFE8F2);
    }

        .cat-icon-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .cat-icon-wrap i {
            font-size: 1.5rem;
            color: #6C3EE8;
        }

    .cat-name {
        font-size: 0.82rem;
        font-weight: 600;
        line-height: 1.3;
    }

    /* ── FEATURE BANNERS ── */
    .feature-banner {
        border-radius: 16px;
        padding: 1.25rem 1rem;
        text-align: center;
        border: 1.5px solid transparent;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .feature-banner:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        }

        .feature-banner.purple {
            background: linear-gradient(135deg, #F3F0FF, #EDE8FF);
            border-color: rgba(108,62,232,0.18);
        }

        .feature-banner.green {
            background: linear-gradient(135deg, #ECFDF5, #D1FAE5);
            border-color: rgba(34,197,94,0.2);
        }

        .feature-banner.orange {
            background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
            border-color: rgba(255,122,47,0.2);
        }

    .feature-icon-wrap {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        margin: 0 auto 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
    }

    .feature-banner.purple .feature-icon-wrap {
        background: rgba(108,62,232,0.15);
        color: #6C3EE8;
    }

    .feature-banner.green .feature-icon-wrap {
        background: rgba(34,197,94,0.15);
        color: #16A34A;
    }

    .feature-banner.orange .feature-icon-wrap {
        background: rgba(255,122,47,0.15);
        color: #EA580C;
    }

    .feature-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #1A1235;
        margin-bottom: 0.2rem;
    }

    .feature-sub {
        font-size: 0.8rem;
        color: #7B6FA0;
    }

    /* ── PRODUCT CARDS ── */
    .product-card {
        background: #fff;
        border-radius: 16px;
        border: 1.5px solid rgba(108,62,232,0.08) !important;
        overflow: hidden;
        transition: transform 0.22s, box-shadow 0.22s;
        position: relative;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 32px rgba(108,62,232,0.14) !important;
        }

    .product-thumb {
        width: 100%;
        aspect-ratio: 4/3;
        object-fit: cover;
        background: #F8F6FF;
        transition: transform 0.35s;
    }

    .product-card:hover .product-thumb {
        transform: scale(1.04);
    }

    .product-thumb-wrap {
        overflow: hidden;
        position: relative;
    }

    .sale-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: linear-gradient(135deg, #FF4F81, #FF7A2F);
        color: #fff;
        font-size: 0.72rem;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 50px;
        letter-spacing: 0.03em;
        z-index: 2;
    }

    .product-card .card-body {
        padding: 0.9rem;
    }

    .product-cat-label {
        font-size: 0.72rem;
        font-weight: 600;
        color: #6C3EE8;
        background: rgba(108,62,232,0.08);
        border-radius: 50px;
        padding: 2px 9px;
        display: inline-block;
        margin-bottom: 0.45rem;
    }

    .product-title a {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1A1235;
        text-decoration: none;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
    }

        .product-title a:hover {
            color: #6C3EE8;
        }

    .price-main {
        font-size: 1rem;
        font-weight: 700;
        color: #6C3EE8;
    }

    .price-old {
        font-size: 0.78rem;
        color: #AAA;
        text-decoration: line-through;
    }

    .out-of-stock-badge {
        font-size: 0.72rem;
        background: #F3F4F6;
        color: #9CA3AF;
        border-radius: 50px;
        padding: 2px 10px;
        font-weight: 600;
    }

    .btn-add-cart {
        background: linear-gradient(135deg, #6C3EE8, #9B6DFF);
        border: none;
        color: #fff;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0.48rem 0;
        width: 100%;
        transition: opacity 0.18s, transform 0.15s;
    }

        .btn-add-cart:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            color: #fff;
        }

    .btn-sold-out {
        background: #F3F4F6;
        border: none;
        color: #9CA3AF;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0.48rem 0;
        width: 100%;
        cursor: not-allowed;
    }

    /* ── RESPONSIVE ── */
    @@media (max-width: 767.98px) {
        .carousel-caption

    {
        right: 10%;
    }

    .feature-banner {
        padding: 1rem 0.75rem;
    }

    }

    @@media (max-width: 575.98px) {
        .carousel-caption

    {
        display: block !important;
        left: 4%;
        right: 4%;
    }

    .carousel-caption h2 {
        font-size: 1.15rem;
    }

    .carousel-caption p {
        display: none;
    }

    }</style>

<!-- ── Hero Slider ──────────────────────────────────────────────────────────── -->
@if (Model.Sliders.Any())
{
    <div class="hero-slider-wrap">
        <div id="heroSlider" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="4500">
            <div class="carousel-indicators">
                @for (int i = 0; i < Model.Sliders.Count; i++)
                {
                    <button type="button" data-bs-target="#heroSlider" data-bs-slide-to="@i"
                            class="@(i == 0 ? "active" : "")" aria-label="Slide @(i + 1)"></button>
                }
            </div>
            <div class="carousel-inner">
                @for (int i = 0; i < Model.Sliders.Count; i++)
                {
                    var s = Model.Sliders[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@s.ImageUrl" class="slider-img d-block"
                             alt="@s.Title"
                             onerror="this.src='https://via.placeholder.com/1400x520/2D1B69/fff?text=ShopMS'" />
                        <div class="hero-overlay"></div>
                        @if (!string.IsNullOrEmpty(s.Title))
                        {
                            <div class="carousel-caption d-block">
                                <h2>@s.Title</h2>
                                @if (!string.IsNullOrEmpty(s.SubTitle))
                                {
                                    <p>@s.SubTitle</p>
                                }
                                @if (!string.IsNullOrEmpty(s.ButtonText))
                                {
                                    <a href="@(s.ButtonUrl ?? "#")" class="btn btn-hero">
                                        @s.ButtonText <i class="bi bi-arrow-right ms-1"></i>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#heroSlider" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#heroSlider" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>
    </div>
}

<div class="container my-4 my-md-5">

    <!-- ── Categories ────────────────────────────────────────────────────────── -->
    @if (Model.Categories.Any())
    {
        <div class="section-header">
            <div class="section-title">
                <span class="section-title-dot"></span>
                ক্যাটাগরি
            </div>
            <a asp-controller="Product" asp-action="Index" class="btn-see-all">
                সব দেখুন <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="row g-2 g-sm-3 mb-5">
            @foreach (var cat in Model.Categories)
            {
                <div class="col-4 col-sm-3 col-md-2">
                    <a href="/Product?categoryId=@cat.Id" class="cat-card">
                        <div class="cat-icon-wrap">
                            @if (!string.IsNullOrEmpty(cat.ImageUrl))
                            {
                                <img src="@cat.ImageUrl"
                                     onerror="this.style.display='none';this.parentElement.innerHTML='<i class=\'bi bi-grid\'></i>'"
                                     alt="@cat.Name" />
                            }
                            else
                            {
                                <i class="bi bi-grid"></i>
                            }
                        </div>
                        <div class="cat-name">@cat.Name</div>
                    </a>
                </div>
            }
        </div>
    }

    <!-- ── Feature Banners ───────────────────────────────────────────────────── -->
    <div class="row g-3 mb-5">
        <div class="col-12 col-md-4">
            <div class="feature-banner purple">
                <div class="feature-icon-wrap"><i class="bi bi-truck-front-fill"></i></div>
                <div class="feature-title">বিনামূল্যে ডেলিভারি</div>
                <div class="feature-sub">৫০০+ টাকার অর্ডারে সারাদেশে</div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="feature-banner green">
                <div class="feature-icon-wrap"><i class="bi bi-shield-fill-check"></i></div>
                <div class="feature-title">১০০% অরিজিনাল</div>
                <div class="feature-sub">গ্যারান্টিযুক্ত পণ্য</div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="feature-banner orange">
                <div class="feature-icon-wrap"><i class="bi bi-arrow-repeat"></i></div>
                <div class="feature-title">সহজ রিটার্ন</div>
                <div class="feature-sub">৭ দিনের মধ্যে রিটার্ন</div>
            </div>
        </div>
    </div>

    <!-- ── New Arrivals ──────────────────────────────────────────────────────── -->
    <div class="section-header">
        <div class="section-title">
            <span class="section-title-dot"></span>
            নতুন পণ্য
        </div>
        <a asp-controller="Product" asp-action="Index" class="btn-see-all">
            সব দেখুন <i class="bi bi-arrow-right"></i>
        </a>
    </div>

    <div class="row g-3">
        @foreach (var p in Model.Products)
        {
            var img = p.Images.FirstOrDefault(i => i.IsPrimary)?.ImageUrl
            ?? p.Images.FirstOrDefault()?.ImageUrl;

            <div class="col-6 col-md-4 col-lg-3">
                <div class="card product-card h-100 shadow-none border-0">

                    <!-- Image -->
                    <div class="product-thumb-wrap">
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id">
                            <img src="@img" class="product-thumb"
                                 onerror="this.src='https://via.placeholder.com/300x225/EDE8FF/6C3EE8?text=ShopMS'"
                                 alt="@p.Name" />
                        </a>
                        @if (p.DiscountPrice.HasValue)
                        {
                            <span class="sale-badge">SALE</span>
                        }
                    </div>

                    <!-- Body -->
                    <div class="card-body d-flex flex-column">
                        @if (p.Category != null)
                        {
                            <span class="product-cat-label">@p.Category.Name</span>
                        }
                        <div class="product-title mb-2">
                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id">@p.Name</a>
                        </div>

                        <!-- Price -->
                        <div class="d-flex align-items-center gap-2 mb-3 mt-auto">
                            @if (p.DiscountPrice.HasValue)
                            {
                                <span class="price-main">৳@p.DiscountPrice.Value.ToString("N0")</span>
                                <span class="price-old">৳@p.Price.ToString("N0")</span>
                            }
                            else
                            {
                                <span class="price-main">৳@p.Price.ToString("N0")</span>
                            }
                            @if (p.Stock == 0)
                            {
                                <span class="out-of-stock-badge ms-auto">স্টক শেষ</span>
                            }
                        </div>

                        <!-- CTA -->
                        @if (p.Stock > 0)
                        {
                            <form asp-controller="Cart" asp-action="Add" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@p.Id" />
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <button type="submit" class="btn-add-cart">
                                        <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ
                                    </button>
                                }
                                else
                                {
                                    <a asp-controller="Account" asp-action="Login" class="btn-add-cart d-block text-center text-decoration-none">
                                        <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ
                                    </a>
                                }
                            </form>
                        }
                        else
                        {
                            <button class="btn-sold-out" disabled>স্টক নেই</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

</div>
