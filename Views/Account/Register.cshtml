@model RegisterViewModel
@{ ViewData["Title"] = "রেজিস্টার"; Layout = "_Layout"; }

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <i class="bi bi-person-plus-fill display-4 text-dark"></i>
                        <h4 class="fw-bold mt-2 mb-0">নতুন অ্যাকাউন্ট তৈরি করুন</h4>
                        <p class="text-muted small">বিনামূল্যে রেজিস্টার করুন</p>
                    </div>

                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-medium small">পুরো নাম <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="আপনার পুরো নাম" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-medium small">ইমেইল <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="your@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-medium small">ফোন নম্বর <span class="text-danger">*</span></label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="01XXXXXXXXX" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-medium small">ঠিকানা</label>
                            <textarea asp-for="Address" class="form-control" rows="2"
                                      placeholder="আপনার ঠিকানা (ঐচ্ছিক)"></textarea>
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Password" class="form-label fw-medium small">পাসওয়ার্ড <span class="text-danger">*</span></label>
                                <input asp-for="Password" type="password" class="form-control" placeholder="কমপক্ষে ৬ অক্ষর" />
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ConfirmPassword" class="form-label fw-medium small">পাসওয়ার্ড নিশ্চিত <span class="text-danger">*</span></label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="পুনরায় লিখুন" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 fw-semibold">
                            <i class="bi bi-person-check me-2"></i>রেজিস্টার করুন
                        </button>
                    </form>

                    <hr class="my-3" />
                    <p class="text-center small mb-0">
                        ইতোমধ্যে অ্যাকাউন্ট আছে?
                        <a asp-action="Login" class="text-dark fw-semibold">লগইন করুন</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
