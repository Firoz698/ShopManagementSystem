<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ShopManagementSystem</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>

<!-- ── Navbar ──────────────────────────────────────────────────────────────── -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
    <div class="container">
        <!-- Logo -->
        <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
            <i class="bi bi-shop me-1 text-warning"></i>ShopMS
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <!-- Search bar -->
            <form class="d-flex mx-auto" style="width:40%" asp-controller="Product" asp-action="Index" method="get">
                <div class="input-group">
                    <input class="form-control" type="search" name="search" placeholder="প্রোডাক্ট খুঁজুন..."
                           value="@Context.Request.Query["search"]" />
                    <button class="btn btn-warning" type="submit">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>

            <!-- Nav links -->
            <ul class="navbar-nav ms-auto align-items-center gap-1">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door me-1"></i>হোম
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-grid me-1"></i>প্রোডাক্ট
                    </a>
                </li>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- Cart -->
                    <li class="nav-item">
                        <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index">
                            <i class="bi bi-cart3 fs-5"></i>
                            @{
                                var cartCount = 0;
                                if (User.Identity.IsAuthenticated)
                                {
                                    var userId = Context.RequestServices
                                        .GetRequiredService<Microsoft.AspNetCore.Identity.UserManager<ShopManagementSystem.Models.ApplicationUser>>()
                                        .GetUserId(User);
                                    var db = Context.RequestServices.GetRequiredService<ShopManagementSystem.Data.ApplicationDbContext>();
                                    cartCount = db.Carts.Count(c => c.UserId == userId);
                                }
                            }
                            @if (cartCount > 0)
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark">
                                    @cartCount
                                </span>
                            }
                        </a>
                    </li>
                    <!-- Wishlist -->
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Wishlist" asp-action="Index">
                            <i class="bi bi-heart fs-5"></i>
                        </a>
                    </li>
                    <!-- User dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i>@User.Identity.Name?.Split('@')[0]
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" asp-controller="Cart" asp-action="MyOrders">
                                <i class="bi bi-bag-check me-2"></i>আমার অর্ডার</a></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="dropdown-item text-danger" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-shield-lock me-2"></i>অ্যাডমিন প্যানেল</a></li>
                            }
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>লগআউট
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm me-1" asp-controller="Account" asp-action="Login">লগইন</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-warning btn-sm" asp-controller="Account" asp-action="Register">রেজিস্টার</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<!-- ── Category quick-links ─────────────────────────────────────────────────── -->
<div class="bg-light border-bottom py-1">
    <div class="container">
        <div class="d-flex gap-3 flex-wrap">
            @{
                var allCats = (ViewBag.NavCategories as List<ShopManagementSystem.Models.Category>)
                    ?? Context.RequestServices
                        .GetRequiredService<ShopManagementSystem.Data.ApplicationDbContext>()
                        .Categories.Where(c => c.IsActive).Take(8).ToList();
            }
            @foreach (var cat in allCats)
            {
                <a href="/Product?categoryId=@cat.Id" class="text-decoration-none small text-secondary fw-medium">
                    @cat.Name
                </a>
            }
        </div>
    </div>
</div>

<!-- ── Alert messages ───────────────────────────────────────────────────────── -->
<div class="container mt-2">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
</div>

<!-- ── Page content ─────────────────────────────────────────────────────────── -->
<main>
    @RenderBody()
</main>

<!-- ── Footer ───────────────────────────────────────────────────────────────── -->
<footer class="bg-dark text-white mt-5 pt-5 pb-3">
    <div class="container">
        <div class="row g-4">
            <!-- Brand -->
            <div class="col-lg-4">
                <h5 class="fw-bold mb-3">
                    <i class="bi bi-shop me-2 text-warning"></i>ShopManagementSystem
                </h5>
                <p class="text-secondary small">
                    সর্বোচ্চ মানের পণ্য, সর্বোত্তম মূল্যে। আমাদের সাথে কেনাকাটার অভিজ্ঞতা উপভোগ করুন।
                </p>
                <div class="d-flex gap-3 mt-3">
                    <a href="#" class="text-warning fs-5"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="text-warning fs-5"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="text-warning fs-5"><i class="bi bi-twitter-x"></i></a>
                </div>
            </div>
            <!-- Quick Links -->
            <div class="col-lg-2 col-md-4">
                <h6 class="fw-bold mb-3 text-warning">দ্রুত লিংক</h6>
                <ul class="list-unstyled small">
                    <li class="mb-2"><a asp-controller="Home" asp-action="Index" class="text-secondary text-decoration-none">হোম</a></li>
                    <li class="mb-2"><a asp-controller="Product" asp-action="Index" class="text-secondary text-decoration-none">সব প্রোডাক্ট</a></li>
                    <li class="mb-2"><a asp-controller="Cart" asp-action="Index" class="text-secondary text-decoration-none">কার্ট</a></li>
                    <li class="mb-2"><a asp-controller="Wishlist" asp-action="Index" class="text-secondary text-decoration-none">উইশলিস্ট</a></li>
                </ul>
            </div>
            <!-- Categories -->
            <div class="col-lg-3 col-md-4">
                <h6 class="fw-bold mb-3 text-warning">ক্যাটাগরি</h6>
                <ul class="list-unstyled small">
                    @foreach (var cat in allCats.Take(5))
                    {
                        <li class="mb-2">
                            <a href="/Product?categoryId=@cat.Id" class="text-secondary text-decoration-none">@cat.Name</a>
                        </li>
                    }
                </ul>
            </div>
            <!-- Contact -->
            <div class="col-lg-3 col-md-4">
                <h6 class="fw-bold mb-3 text-warning">যোগাযোগ</h6>
                <ul class="list-unstyled small text-secondary">
                    <li class="mb-2"><i class="bi bi-telephone me-2"></i>+880 1700-000000</li>
                    <li class="mb-2"><i class="bi bi-envelope me-2"></i>info@shopms.com</li>
                    <li class="mb-2"><i class="bi bi-geo-alt me-2"></i>ঢাকা, বাংলাদেশ</li>
                    <li class="mb-2"><i class="bi bi-clock me-2"></i>শনি–বৃহঃ, ৯টা–৬টা</li>
                </ul>
            </div>
        </div>

        <hr class="border-secondary mt-4" />
        <div class="d-flex flex-wrap justify-content-between align-items-center">
            <p class="text-secondary small mb-0">
                &copy; @DateTime.Now.Year ShopManagementSystem. সকল স্বত্ব সংরক্ষিত।
            </p>
            <p class="text-secondary small mb-0">
                Developed by <span class="text-warning fw-semibold">Md Firoz</span>
            </p>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
