@model ProductDetailViewModel
@{
    ViewData["Title"] = Model.Product.Name;
}

<div class="container my-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">হোম</a></li>
            <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index">প্রোডাক্ট</a></li>
            <li class="breadcrumb-item active">@Model.Product.Name</li>
        </ol>
    </nav>

    <div class="row g-4 mb-5">
        <!-- ── Images ──────────────────────────────────────────────────────── -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm p-2">
                <img id="mainImg"
                     src="@(Model.Product.Images.FirstOrDefault(i => i.IsPrimary)?.ImageUrl ?? Model.Product.Images.FirstOrDefault()?.ImageUrl ?? "https://via.placeholder.com/500x400/f8f9fa/6c757d?text=No+Image")"
                     class="img-fluid rounded-2"
                     style="height:380px;object-fit:contain;width:100%"
                     alt="@Model.Product.Name" />
            </div>
            @if (Model.Product.Images.Count > 1)
            {
                <div class="d-flex gap-2 mt-2 flex-wrap">
                    @foreach (var img in Model.Product.Images)
                    {
                        <img src="@img.ImageUrl"
                             onclick="document.getElementById('mainImg').src='@img.ImageUrl';setActiveThumb(this)"
                             class="rounded border thumb-img @(img.IsPrimary ? "border-dark border-2" : "")"
                             style="width:64px;height:64px;object-fit:cover;cursor:pointer"
                             alt="thumb" />
                    }
                </div>
            }
        </div>

        <!-- ── Details ─────────────────────────────────────────────────────── -->
        <div class="col-lg-7">
            <div class="small text-muted mb-1">@Model.Product.Category?.Name</div>
            <h2 class="fw-bold mb-1">@Model.Product.Name</h2>

            @if (!string.IsNullOrEmpty(Model.Product.ProductCode))
            {
                <div class="text-muted small mb-2">কোড: <code>@Model.Product.ProductCode</code></div>
            }

            <!-- Rating -->
            <div class="d-flex align-items-center gap-2 mb-3">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="bi @(i <= Math.Round(Model.AvgRating) ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
                }
                <span class="small text-muted">(@Model.Reviews.Count টি রিভিউ)</span>
            </div>

            <!-- Price -->
            <div id="priceSection" class="mb-3">
                @if (Model.Product.DiscountPrice.HasValue && IsDiscountActive(Model.Product))
                {
                    <div class="d-flex align-items-center gap-3">
                        <span id="displayPrice" class="fs-3 fw-bold text-danger">
                            ৳@Model.Product.DiscountPrice.Value.ToString("N0")
                        </span>
                        <span class="fs-5 text-muted text-decoration-line-through">
                            ৳@Model.Product.Price.ToString("N0")
                        </span>
                        @{
                            var discPct = Math.Round((1 - Model.Product.DiscountPrice.Value / Model.Product.Price) * 100);
                        }
                        <span class="badge bg-danger">@discPct% ছাড়</span>
                    </div>
                }
                else
                {
                    <span id="displayPrice" class="fs-3 fw-bold">৳@Model.Product.Price.ToString("N0")</span>
                }
                @if (Model.Product.ProductVat > 0)
                {
                    <div class="text-muted small mt-1">
                        <i class="bi bi-info-circle me-1"></i>VAT @Model.Product.ProductVat% অন্তর্ভুক্ত
                    </div>
                }
            </div>

            <!-- ── Size Selection ───────────────────────────────────────────── -->
            @if (Model.Product.Sizes.Any(s => s.IsActive))
            {
                <div class="mb-3">
                    <label class="form-label fw-medium">সাইজ নির্বাচন করুন <span class="text-danger">*</span></label>
                    <div class="d-flex flex-wrap gap-2" id="sizeOptions">
                        @foreach (var size in Model.Product.Sizes.Where(s => s.IsActive))
                        {
                            <button type="button"
                                    class="btn btn-outline-dark size-btn"
                                    data-size-id="@size.Id"
                                    data-size-price="@size.SalesPrice"
                                    data-size-stock="@size.Stock"
                                    onclick="selectSize(this)"
                                    @(size.Stock == 0 ? "disabled" : "")>
                                @size.SizeName
                                @if (size.Stock == 0)
                                {
                                    <span class="d-block" style="font-size:.65rem">শেষ</span>
                                }
                            </button>
                        }
                    </div>
                    <div id="sizeError" class="text-danger small mt-1" style="display:none">
                        অনুগ্রহ করে একটি সাইজ নির্বাচন করুন
                    </div>
                </div>
            }

            <!-- Stock -->
            <div class="mb-3" id="stockBadge">
                @if (Model.Product.Stock > 0)
                {
                    <span class="badge bg-success-subtle text-success px-3 py-2">
                        <i class="bi bi-check-circle me-1"></i>স্টকে আছে (@Model.Product.Stock টি)
                    </span>
                }
                else
                {
                    <span class="badge bg-danger-subtle text-danger px-3 py-2">
                        <i class="bi bi-x-circle me-1"></i>স্টক শেষ
                    </span>
                }
            </div>

            <!-- ── Add to Cart (Ajax) ─────────────────────────────────────── -->
            @if (Model.Product.Stock > 0)
            {
                <div class="d-flex gap-2 mb-3" id="addCartSection">
                    <div class="input-group" style="width:130px">
                        <button type="button" class="btn btn-outline-secondary" onclick="changeQty(-1)">−</button>
                        <input type="number" id="qtyInput" value="1" min="1"
                               max="@Model.Product.Stock" class="form-control text-center" />
                        <button type="button" class="btn btn-outline-secondary" onclick="changeQty(1)">+</button>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button type="button" class="btn btn-dark px-4" onclick="addMainToCart(@Model.Product.Id)">
                            <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ করুন
                        </button>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-dark px-4">
                            <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ করুন
                        </a>
                    }
                </div>

                <!-- Ajax feedback -->
                <div id="cartFeedback" class="alert py-2 small" style="display:none"></div>
            }
            else
            {
                <button class="btn btn-secondary btn-lg" disabled>স্টক নেই</button>
            }

            <!-- Wishlist -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Wishlist" asp-action="Toggle" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Product.Id" />
                    <button type="submit" class="btn @(Model.IsInWishlist ? "btn-danger" : "btn-outline-danger") btn-sm">
                        <i class="bi @(Model.IsInWishlist ? "bi-heart-fill" : "bi-heart") me-1"></i>
                        @(Model.IsInWishlist ? "উইশলিস্টে আছে" : "উইশলিস্টে যোগ করুন")
                    </button>
                </form>
            }

            <!-- Description -->
            @if (!string.IsNullOrWhiteSpace(Model.Product.Description))
            {
                <hr />
                <h6 class="fw-semibold">বিবরণ</h6>
                <p class="text-muted">@Model.Product.Description</p>
            }
        </div>
    </div>

    <!-- ── Reviews ──────────────────────────────────────────────────────────── -->
    <div class="row mb-5">
        <div class="col-lg-8">
            <h5 class="fw-bold mb-3">রিভিউ ও রেটিং</h5>
            @if (User.Identity?.IsAuthenticated == true && !Model.UserReviewed)
            {
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-3">আপনার রিভিউ লিখুন</h6>
                        <form asp-controller="Product" asp-action="AddReview" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ProductId" value="@Model.Product.Id" />
                            <div class="mb-3">
                                <label class="form-label small fw-medium">রেটিং</label>
                                <select name="Rating" class="form-select form-select-sm" style="width:160px" required>
                                    <option value="5">⭐⭐⭐⭐⭐ চমৎকার</option>
                                    <option value="4">⭐⭐⭐⭐ ভালো</option>
                                    <option value="3">⭐⭐⭐ মোটামুটি</option>
                                    <option value="2">⭐⭐ খারাপ</option>
                                    <option value="1">⭐ খুব খারাপ</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <textarea name="Comment" class="form-control" rows="3"
                                      placeholder="আপনার অভিজ্ঞতা শেয়ার করুন..."></textarea>
                            </div>
                            <button type="submit" class="btn btn-dark btn-sm">রিভিউ জমা দিন</button>
                        </form>
                    </div>
                </div>
            }
            @if (!Model.Reviews.Any())
            {
                <p class="text-muted small">এখনো কোনো রিভিউ নেই।</p>
            }
            @foreach (var r in Model.Reviews)
            {
                <div class="card border-0 shadow-sm mb-2">
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between">
                            <div>
                                <span class="fw-semibold small">@r.User?.FullName</span>
                                <div class="d-flex gap-1 my-1">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= r.Rating ? "bi-star-fill text-warning" : "bi-star text-muted") small"></i>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(r.Comment))
                                {
                                    <p class="mb-0 text-muted small">@r.Comment</p>
                                }
                            </div>
                            <small class="text-muted">@r.CreatedAt.ToString("dd MMM yyyy")</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- ── Related Products ─────────────────────────────────────────────────── -->
    @if (Model.RelatedItems.Any())
    {
        <h5 class="fw-bold mb-3">সম্পর্কিত পণ্য</h5>
        <div class="row g-3">
            @foreach (var p in Model.RelatedItems)
            {
                var img2 = p.Images.FirstOrDefault(i => i.IsPrimary)?.ImageUrl ?? p.Images.FirstOrDefault()?.ImageUrl;
                var relPrice = p.DiscountPrice ?? p.Price;
                <div class="col-6 col-md-3">
                    <div class="card border-0 shadow-sm h-100 product-card">
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id">
                            <img src="@img2" class="card-img-top product-thumb"
                                 onerror="this.src='https://via.placeholder.com/300x220/f8f9fa/6c757d?text=No+Image'"
                                 alt="@p.Name" />
                        </a>
                        <div class="card-body p-2">
                            <div class="small fw-semibold product-title">@p.Name</div>
                            <div class="small fw-bold text-danger mt-1">৳@relPrice.ToString("N0")</div>
                        </div>
                        <div class="card-footer bg-transparent border-0 pt-0 pb-2 px-2">
                            @if (p.Stock > 0)
                            {
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <button type="button"
                                            class="btn btn-dark btn-sm w-100"
                                            onclick="addRelatedToCart(@p.Id, this)">
                                        <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ
                                    </button>
                                }
                                else
                                {
                                    <a asp-controller="Account" asp-action="Login"
                                       class="btn btn-dark btn-sm w-100">
                                        <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ
                                    </a>
                                }
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-sm w-100" disabled>স্টক নেই</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        // ── Hidden CSRF token ────────────────────────────────────────────────────
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        // ── Qty control ──────────────────────────────────────────────────────────
        function changeQty(delta) {
            var input = document.getElementById('qtyInput');
            var val = parseInt(input.value) + delta;
            input.value = Math.max(1, Math.min(val, parseInt(input.max)));
        }

        // ── Size selection ───────────────────────────────────────────────────────
        var selectedSizeId    = null;
        var selectedSizePrice = null;

        function selectSize(btn) {
            document.querySelectorAll('.size-btn').forEach(function(b) {
                b.classList.remove('btn-dark');
                b.classList.add('btn-outline-dark');
            });
            btn.classList.remove('btn-outline-dark');
            btn.classList.add('btn-dark');

            selectedSizeId    = btn.dataset.sizeId;
            selectedSizePrice = parseFloat(btn.dataset.sizePrice);
            var stock         = parseInt(btn.dataset.sizeStock);

            // Price update
            document.getElementById('displayPrice').textContent = '৳' + selectedSizePrice.toLocaleString('bn-BD');

            // Stock update
            document.getElementById('qtyInput').max = stock;
            document.getElementById('stockBadge').innerHTML =
                '<span class="badge bg-success-subtle text-success px-3 py-2">' +
                '<i class="bi bi-check-circle me-1"></i>স্টকে আছে (' + stock + ' টি)</span>';

            document.getElementById('sizeError').style.display = 'none';
        }

        // ── Thumbnail active ─────────────────────────────────────────────────────
        function setActiveThumb(img) {
            document.querySelectorAll('.thumb-img').forEach(function(t) {
                t.classList.remove('border-dark', 'border-2');
            });
            img.classList.add('border-dark', 'border-2');
        }

        // ── Main Product কার্টে যোগ (size validation সহ) ────────────────────────
        function addMainToCart(productId) {
            var hasSizes = document.querySelectorAll('.size-btn').length > 0;
            var sizeId   = null;

            if (hasSizes) {
                sizeId = selectedSizeId;
                if (!sizeId) {
                    document.getElementById('sizeError').style.display = 'block';
                    return;
                }
            }

            var quantity = parseInt(document.getElementById('qtyInput')?.value || 1);
            doAddToCart(productId, sizeId, quantity, null);
        }

        // ── Related Product কার্টে যোগ (size validation নেই) ────────────────────
        function addRelatedToCart(productId, btnEl) {
            doAddToCart(productId, null, 1, btnEl);
        }

        // ── Shared fetch logic ───────────────────────────────────────────────────
        function doAddToCart(productId, sizeId, quantity, btnEl) {
            if (btnEl) {
                btnEl.disabled = true;
                btnEl.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>যোগ হচ্ছে...';
            }

            var formData = new FormData();
            formData.append('productId', productId);
            formData.append('quantity',  quantity);
            formData.append('__RequestVerificationToken', token);
            if (sizeId) formData.append('productSizeId', sizeId);

            fetch('/Cart/AddAjax', {
                method: 'POST',
                body: formData
            })
            .then(function(res) { return res.json(); })
            .then(function(data) {
                if (data.success) {
                    // ── Cart badge update ────────────────────────────────────────
                    var badge = document.querySelector('.navbar .badge');
                    if (badge) {
                        badge.textContent = data.cartCount;
                    } else {
                        var cartIcon = document.querySelector('a[href="/Cart"] i');
                        if (cartIcon) {
                            var sp = document.createElement('span');
                            sp.className = 'position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark';
                            sp.textContent = data.cartCount;
                            cartIcon.parentElement.style.position = 'relative';
                            cartIcon.parentElement.appendChild(sp);
                        }
                    }

                    // ── Main product feedback ────────────────────────────────────
                    var fb = document.getElementById('cartFeedback');
                    if (fb && !btnEl) {
                        fb.className = 'alert alert-success py-2 small';
                        fb.textContent = '✅ কার্টে যোগ হয়েছে!';
                        fb.style.display = 'block';
                        setTimeout(function() { fb.style.display = 'none'; }, 3000);
                    }

                    // ── Related product button feedback ──────────────────────────
                    if (btnEl) {
                        btnEl.disabled = false;
                        btnEl.innerHTML = '<i class="bi bi-check-circle me-1 text-success"></i>যোগ হয়েছে!';
                        setTimeout(function() {
                            btnEl.innerHTML = '<i class="bi bi-cart-plus me-1"></i>কার্টে যোগ';
                        }, 2000);
                    }
                } else {
                    alert(data.message || 'কার্টে যোগ করা যায়নি।');
                    if (btnEl) {
                        btnEl.disabled = false;
                        btnEl.innerHTML = '<i class="bi bi-cart-plus me-1"></i>কার্টে যোগ';
                    }
                }
            })
            .catch(function() {
                alert('সংযোগ সমস্যা। আবার চেষ্টা করুন।');
                if (btnEl) {
                    btnEl.disabled = false;
                    btnEl.innerHTML = '<i class="bi bi-cart-plus me-1"></i>কার্টে যোগ';
                }
            });
        }
    </script>
}

@functions {
    bool IsDiscountActive(ShopManagementSystem.Models.Product p)
    {
        if (!p.DiscountPrice.HasValue) return false;
        var now = DateTime.Now;
        if (p.DiscountStartDate.HasValue && now < p.DiscountStartDate.Value) return false;
        if (p.DiscountEndDate.HasValue && now > p.DiscountEndDate.Value) return false;
        return true;
    }
}
