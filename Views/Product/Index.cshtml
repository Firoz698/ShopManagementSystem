@model ProductListViewModel
@{ ViewData["Title"] = "সব প্রোডাক্ট"; }

<div class="container my-4">
    <div class="row g-4">

        <!-- ── Sidebar Filters ─────────────────────────────────────────────── -->
        <div class="col-lg-3">
            <form method="get" asp-controller="Product" asp-action="Index">
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-header bg-dark text-white fw-semibold">
                        <i class="bi bi-funnel me-2"></i>ফিল্টার
                    </div>
                    <div class="card-body">
                        <!-- Search -->
                        <div class="mb-3">
                            <label class="form-label fw-medium small">সার্চ</label>
                            <input type="text" name="search" class="form-control form-control-sm"
                                   placeholder="প্রোডাক্টের নাম..." value="@Model.SearchTerm" />
                        </div>

                        <!-- Categories -->
                        <div class="mb-3">
                            <label class="form-label fw-medium small">ক্যাটাগরি</label>
                            @foreach (var cat in Model.Categories)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="categoryId"
                                           value="@cat.Id" id="cat@cat.Id"
                                           @(Model.CategoryId == cat.Id ? "checked" : "") />
                                    <label class="form-check-label small" for="cat@cat.Id">@cat.Name</label>
                                </div>
                            }
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="categoryId" value=""
                                       id="catAll" @(Model.CategoryId == null ? "checked" : "") />
                                <label class="form-check-label small" for="catAll">সব ক্যাটাগরি</label>
                            </div>
                        </div>

                        <!-- Price Range -->
                        <div class="mb-3">
                            <label class="form-label fw-medium small">মূল্য পরিসর (৳)</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="number" name="minPrice" class="form-control form-control-sm"
                                           placeholder="সর্বনিম্ন" value="@Model.MinPrice" min="0" />
                                </div>
                                <div class="col-6">
                                    <input type="number" name="maxPrice" class="form-control form-control-sm"
                                           placeholder="সর্বোচ্চ" value="@Model.MaxPrice" min="0" />
                                </div>
                            </div>
                        </div>

                        <!-- Sort -->
                        <div class="mb-3">
                            <label class="form-label fw-medium small">সাজানো</label>
                            <select name="sortBy" class="form-select form-select-sm">
                                <option value="">নতুন আগে</option>
                                <option value="price_asc"  @@(Model.SortBy == "price_asc"  ? "selected" : "")>মূল্য: কম থেকে বেশি</option>
                                <option value="price_desc" @@(Model.SortBy == "price_desc" ? "selected" : "")>মূল্য: বেশি থেকে কম</option>
                                <option value="name"       @@(Model.SortBy == "name"       ? "selected" : "")>নাম অনুযায়ী</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-dark btn-sm w-100">ফিল্টার করুন</button>
                        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary btn-sm w-100 mt-2">রিসেট</a>
                    </div>
                </div>
            </form>
        </div>

        <!-- ── Product Grid ────────────────────────────────────────────────── -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="text-muted small">
                    মোট <strong>@Model.TotalCount</strong>টি প্রোডাক্ট পাওয়া গেছে
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    { <span>"@Model.SearchTerm"</span> }
                </div>
            </div>

            @if (!Model.Products.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-search display-3 d-block mb-3 opacity-25"></i>
                    <h5>কোনো প্রোডাক্ট পাওয়া যায়নি</h5>
                    <p>ভিন্ন কীওয়ার্ড বা ফিল্টার ব্যবহার করুন।</p>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var p in Model.Products)
                    {
                        var img = p.Images.FirstOrDefault(i => i.IsPrimary)?.ImageUrl ?? p.Images.FirstOrDefault()?.ImageUrl;
                        <div class="col-6 col-md-4">
                            <div class="card product-card h-100 border-0 shadow-sm position-relative">
                                @if (p.DiscountPrice.HasValue)
                                {
                                    <span class="badge bg-danger position-absolute top-0 end-0 m-2 z-1">Sale</span>
                                }
                                <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id">
                                    <img src="@img" class="card-img-top product-thumb"
                                         onerror="this.src='https://via.placeholder.com/300x220/f8f9fa/6c757d?text=No+Image'"
                                         alt="@p.Name" />
                                </a>
                                <div class="card-body p-3">
                                    <div class="small text-muted mb-1">@p.Category?.Name</div>
                                    <h6 class="fw-semibold mb-2 product-title">
                                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.Id"
                                           class="text-decoration-none text-dark">@p.Name</a>
                                    </h6>
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        @if (p.DiscountPrice.HasValue)
                                        {
                                            <span class="fw-bold text-danger">৳@p.DiscountPrice.Value.ToString("N0")</span>
                                            <span class="text-muted small text-decoration-line-through">৳@p.Price.ToString("N0")</span>
                                        }
                                        else
                                        {
                                            <span class="fw-bold">৳@p.Price.ToString("N0")</span>
                                        }
                                    </div>
                                    @if (p.Stock <= 5 && p.Stock > 0)
                                    {
                                        <small class="text-warning"><i class="bi bi-exclamation-circle me-1"></i>মাত্র @p.Stock টি বাকি</small>
                                    }
                                </div>
                                <div class="card-footer bg-transparent border-0 pt-0 pb-3 px-3">
                                    @if (p.Stock > 0)
                                    {
                                        <form asp-controller="Cart" asp-action="Add" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@p.Id" />
                                            @if (User.Identity?.IsAuthenticated == true)
                                            {
                                                <button class="btn btn-dark btn-sm w-100">
                                                    <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ
                                                </button>
                                            }
                                            else
                                            {
                                                <a asp-controller="Account" asp-action="Login" class="btn btn-dark btn-sm w-100">
                                                    <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ
                                                </a>
                                            }
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary btn-sm w-100" disabled>স্টক নেই</button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Page ? "active" : "")">
                                    <a class="page-link" href="?search=@Model.SearchTerm&categoryId=@Model.CategoryId&minPrice=@Model.MinPrice&maxPrice=@Model.MaxPrice&sortBy=@Model.SortBy&page=@i">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>
