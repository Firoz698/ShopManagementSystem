@model List<ShopManagementSystem.Models.ComboOffer>
@{
    ViewData["Title"] = "কম্বো অফার";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0"><i class="bi bi-gift text-danger me-2"></i>কম্বো অফার</h4>
            <p class="text-muted small mb-0">একসাথে কিনুন, বেশি সাশ্রয় করুন</p>
        </div>
        <a asp-controller="Product" asp-action="Index" class="btn btn-sm btn-outline-dark">
            <i class="bi bi-arrow-left me-1"></i>সব পণ্য
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-gift display-2 d-block mb-3 opacity-25"></i>
            <h5>এই মুহূর্তে কোনো কম্বো অফার নেই</h5>
            <p class="small">শীঘ্রই আসছে। নিয়মিত চেক করুন!</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-dark mt-2">সব পণ্য দেখুন</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var combo in Model)
            {
                var savings = combo.OriginalPrice.HasValue
                ? combo.OriginalPrice.Value - combo.ComboPrice : 0;
                var savePct = combo.OriginalPrice.HasValue && combo.OriginalPrice > 0
                ? Math.Round(savings / combo.OriginalPrice.Value * 100) : 0;

                <!-- Countdown timer -->
                var timeLeft = combo.EndDate.HasValue
                ? (combo.EndDate.Value - DateTime.Now).TotalSeconds : 0;

                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100 combo-card overflow-hidden">

                        <!-- Banner / Auto image -->
                        <div class="position-relative">
                            @if (!string.IsNullOrEmpty(combo.BannerImageUrl))
                            {
                                <img src="@combo.BannerImageUrl" class="card-img-top"
                                     style="height:200px;object-fit:cover" alt="@combo.Title"
                                     onerror="this.style.display='none'" />
                            }
                            else
                            {
                                <div class="d-flex" style="height:180px;background:#f1f3f5;overflow:hidden">
                                    @foreach (var item in combo.Items.Take(3))
                                    {
                                        var pImg = item.Product?.Images.FirstOrDefault(i => i.IsPrimary)?.ImageUrl
                                        ?? item.Product?.Images.FirstOrDefault()?.ImageUrl;
                                        <div class="flex-fill overflow-hidden position-relative">
                                            <img src="@pImg"
                                                 style="width:100%;height:180px;object-fit:cover"
                                                 onerror="this.src='https://via.placeholder.com/200x180/e9ecef/6c757d?text=+'"
                                                 alt="@item.Product?.Name" />
                                            @if (combo.Items.Count > 1)
                                            {
                                                <div class="position-absolute bottom-0 start-0 end-0 text-center py-1"
                                                     style="background:rgba(0,0,0,.4);font-size:.7rem;color:#fff">
                                                    @item.Product?.Name
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }

                            <!-- Save badge -->
                            @if (savePct > 0)
                            {
                                <span class="position-absolute top-0 start-0 m-2 badge bg-danger fs-6 px-3 py-2">
                                    @savePct% সাশ্রয়
                                </span>
                            }

                            <!-- Countdown -->
                            @if (combo.EndDate.HasValue && timeLeft > 0)
                            {
                                <div class="position-absolute top-0 end-0 m-2">
                                    <div class="badge bg-dark px-2 py-2 countdown-badge"
                                         data-seconds="@((int)timeLeft)" id="countdown_@combo.Id">
                                        <i class="bi bi-clock me-1"></i>
                                        <span class="countdown-text">লোড হচ্ছে...</span>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="card-body">
                            <h5 class="fw-bold mb-2">@combo.Title</h5>
                            @if (!string.IsNullOrEmpty(combo.Description))
                            {
                                <p class="text-muted small mb-3">@combo.Description</p>
                            }

                            <!-- Product list with images -->
                            <div class="mb-3">
                                <div class="fw-medium small mb-2 text-muted">এই কম্বোতে আছে:</div>
                                @foreach (var item in combo.Items)
                                {
                                    var pImg2 = item.Product?.Images.FirstOrDefault(i => i.IsPrimary)?.ImageUrl
                                    ?? item.Product?.Images.FirstOrDefault()?.ImageUrl;
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <img src="@pImg2" class="rounded"
                                             style="width:40px;height:40px;object-fit:cover;flex-shrink:0"
                                             onerror="this.src='https://via.placeholder.com/40'" alt="" />
                                        <div>
                                            <div class="small fw-medium">@item.Product?.Name</div>
                                            <div class="text-muted" style="font-size:.75rem">
                                                ৳@((item.Product?.DiscountPrice ?? item.Product?.Price ?? 0).ToString("N0"))
                                                @if (item.Quantity > 1)
                                                {
                                                    <span>× @item.Quantity</span>
                                                }
                                            </div>
                                        </div>
                                        <i class="bi bi-check-circle-fill text-success ms-auto flex-shrink-0"></i>
                                    </div>
                                }
                            </div>

                            <!-- Price comparison -->
                            <div class="bg-light rounded-3 p-3 mb-3">
                                @if (combo.OriginalPrice.HasValue)
                                {
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="small text-muted">আলাদা কিনলে</span>
                                        <span class="small text-muted text-decoration-line-through">
                                            ৳@combo.OriginalPrice.Value.ToString("N0")
                                        </span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="small text-success fw-medium">আপনি বাঁচাচ্ছেন</span>
                                        <span class="small text-success fw-bold">-৳@savings.ToString("N0")</span>
                                    </div>
                                    <hr class="my-2" />
                                }
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold">কম্বো মূল্য</span>
                                    <span class="fs-4 fw-bold text-danger">৳@combo.ComboPrice.ToString("N0")</span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 pb-4 px-3 d-flex gap-2">
                            <a asp-controller="Combo" asp-action="Detail" asp-route-id="@combo.Id"
                               class="btn btn-outline-dark btn-sm flex-fill">
                                <i class="bi bi-eye me-1"></i>বিস্তারিত
                            </a>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-controller="Combo" asp-action="AddToCart" method="post" class="flex-fill">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@combo.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm w-100 fw-semibold">
                                        <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ করুন
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Login"
                                   class="btn btn-danger btn-sm flex-fill fw-semibold">
                                    <i class="bi bi-cart-plus me-1"></i>কার্টে যোগ করুন
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .combo-card {
        transition: transform .22s, box-shadow .22s;
    }

        .combo-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 16px 40px rgba(0,0,0,.12) !important;
        }
</style>

@section Scripts {
    <script>
        // Countdown timer
        document.querySelectorAll('.countdown-badge').forEach(function(badge) {
            var seconds = parseInt(badge.dataset.seconds);
            var el      = badge.querySelector('.countdown-text');

            function update() {
                if (seconds <= 0) { el.textContent = 'শেষ!'; badge.classList.add('bg-secondary'); return; }
                var d = Math.floor(seconds / 86400);
                var h = Math.floor((seconds % 86400) / 3600);
                var m = Math.floor((seconds % 3600) / 60);
                var s = seconds % 60;
                el.textContent = d > 0
                    ? d + 'দ ' + h + 'ঘ ' + m + 'মি'
                    : h + 'ঘ ' + m + 'মি ' + s + 'সে';
                seconds--;
            }
            update();
            setInterval(update, 1000);
        });
    </script>
}
