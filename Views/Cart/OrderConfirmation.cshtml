@model ShopManagementSystem.Models.Order
@{ ViewData["Title"] = "অর্ডার নিশ্চিত হয়েছে"; }

<div class="container my-5 text-center">
    <div class="card border-0 shadow-sm mx-auto" style="max-width:600px">
        <div class="card-body py-5">
            <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-4"
                 style="width:80px;height:80px">
                <i class="bi bi-check-circle-fill text-success" style="font-size:2.5rem"></i>
            </div>
            <h3 class="fw-bold text-success mb-2">অর্ডার সফল হয়েছে!</h3>
            <p class="text-muted mb-1">অর্ডার নম্বর: <strong>#@Model.Id</strong></p>
            <p class="text-muted mb-4">আমরা শীঘ্রই আপনার সাথে যোগাযোগ করব।</p>

            <div class="table-responsive text-start mb-4">
                <table class="table table-sm">
                    <thead class="table-dark">
                        <tr>
                            <th>পণ্য</th>
                            <th class="text-center">পরিমাণ</th>
                            <th class="text-end">মূল্য</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.OrderDetails)
                        {
                            <tr>
                                <td>@d.Product?.Name</td>
                                <td class="text-center">@d.Quantity</td>
                                <td class="text-end">৳@((d.UnitPrice * d.Quantity).ToString("N0"))</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold">
                            <td colspan="2">মোট</td>
                            <td class="text-end text-danger">৳@Model.TotalAmount.ToString("N0")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="text-start bg-light rounded p-3 mb-4">
                <div><strong>ঠিকানা:</strong> @Model.ShippingAddress</div>
                <div><strong>ফোন:</strong> @Model.Phone</div>
                <div><strong>পেমেন্ট:</strong> @Model.PaymentMethod</div>
                <div><strong>স্ট্যাটাস:</strong>
                    <span class="badge bg-warning text-dark">@Model.Status</span>
                </div>
            </div>

            <div class="d-flex gap-2 justify-content-center">
                <a asp-action="MyOrders" class="btn btn-dark">আমার অর্ডার দেখুন</a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">হোমে যান</a>
            </div>
        </div>
    </div>
</div>
