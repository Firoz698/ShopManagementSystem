@model ShopManagementSystem.Models.PaymentTransaction?
@{ ViewData["Title"] = "পেমেন্ট ব্যর্থ"; }

<div class="container my-5 text-center">
    <div class="card border-0 shadow-sm mx-auto" style="max-width:520px">
        <div class="card-body py-5">
            <div class="rounded-circle bg-danger bg-opacity-10 d-inline-flex align-items-center
                        justify-content-center mb-4" style="width:80px;height:80px">
                <i class="bi bi-x-circle-fill text-danger" style="font-size:2.5rem"></i>
            </div>
            <h3 class="fw-bold text-danger mb-2">পেমেন্ট ব্যর্থ হয়েছে!</h3>
            <p class="text-muted mb-1">
                @if (Model != null)
                {
                    <span>ট্রানজেকশন আইডি: <strong>@Model.TransactionId</strong></span>
                }
            </p>
            <p class="text-muted mb-4">
                পেমেন্ট প্রক্রিয়া সম্পন্ন হয়নি। আবার চেষ্টা করুন।
            </p>

            <div class="d-flex gap-2 justify-content-center">
                @if (Model?.OrderId > 0)
                {
                    <!-- অর্ডারটি এখনও আছে — আবার পেমেন্ট করতে পারবে -->
                    <a asp-action="RetryPayment" asp-route-orderId="@Model.OrderId"
                       class="btn btn-primary px-4">
                        <i class="bi bi-arrow-repeat me-2"></i>আবার পেমেন্ট করুন
                    </a>
                }
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                    হোমে যান
                </a>
            </div>
        </div>
    </div>
</div>
