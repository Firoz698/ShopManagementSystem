@model ShopManagementSystem.Models.PaymentTransaction?
@{ ViewData["Title"] = "পেমেন্ট বাতিল"; }

<div class="container my-5 text-center">
    <div class="card border-0 shadow-sm mx-auto" style="max-width:520px">
        <div class="card-body py-5">
            <div class="rounded-circle bg-warning bg-opacity-10 d-inline-flex align-items-center
                        justify-content-center mb-4" style="width:80px;height:80px">
                <i class="bi bi-slash-circle-fill text-warning" style="font-size:2.5rem"></i>
            </div>
            <h3 class="fw-bold text-warning mb-2">পেমেন্ট বাতিল করা হয়েছে</h3>
            <p class="text-muted mb-4">
                আপনি পেমেন্ট বাতিল করেছেন। অর্ডারটি সংরক্ষিত আছে।
                চাইলে আবার পেমেন্ট করতে পারবেন।
            </p>
            <div class="d-flex gap-2 justify-content-center">
                @if (Model?.OrderId > 0)
                {
                    <a asp-action="RetryPayment" asp-route-orderId="@Model.OrderId"
                       class="btn btn-dark px-4">
                        <i class="bi bi-arrow-repeat me-2"></i>আবার পেমেন্ট করুন
                    </a>
                }
                <a asp-action="MyOrders" class="btn btn-outline-secondary">
                    আমার অর্ডার দেখুন
                </a>
            </div>
        </div>
    </div>
</div>
